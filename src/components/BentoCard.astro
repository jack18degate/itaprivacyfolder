---
interface Props {
  href?: string;
  title?: string;
  subtitle?: string;
  class?: string;
}
const { href, title, subtitle, class: className = '' } = Astro.props;
const Container = href ? 'a' : 'div';
const interactiveModifier = href ? 'bento-card-interactive' : 'bento-card';
---

<Container href={href} class={`${interactiveModifier} ${className} flex flex-col justify-between h-full group`}>
  <div>
    <div class="flex items-start justify-between gap-4">
      {title && <h3 class="text-title w-[90%]">{title}</h3>}
      {href && (
         <div class="w-6 h-6 rounded-full bg-white/[0.03] group-hover:bg-white/[0.1] transition-colors flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-zinc-500 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
         </div>
      )}
    </div>
    {subtitle && <p class="text-subtitle">{subtitle}</p>}
  </div>
  {Astro.slots.has('default') && <div class="mt-2"><slot /></div>}
</Container>
