---
interface Field {
  key: string;
  label: string;
  type?: 'text' | 'list' | 'badge';
}

interface Item {
  id: string;
  nome: string;
  logo: string;
  badge?: string;
  categoria_badge?: string;
  [key: string]: any;
}

interface Props {
  items: Item[];
  fields: Field[];
  tableTitle?: string;
}

const { items, fields, tableTitle = "Confronto Interattivo" } = Astro.props;
---

<div class="compare-module bento-card p-4 lg:p-6 mb-8 mt-4 bg-gradient-to-br from-[#0066FF]/5 to-transparent border-[var(--border-card)]" data-items={JSON.stringify(items)} data-fields={JSON.stringify(fields)}>
  <h3 class="text-xl md:text-2xl font-bold text-[var(--text-heading)] mb-2 flex items-center gap-2">
    <svg class="w-6 h-6 text-[#0066FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
    {tableTitle}
  </h3>
  <p class="text-sm text-[var(--text-body)] mb-6">Trascina o clicca gli elementi qui sotto per confrontarne le caratteristiche affiancate.</p>
  
  <div class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="text-xs text-slate-500 uppercase tracking-widest font-bold">Elementi Disponibili</div>
      <div class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold flex items-center gap-1.5 opacity-80">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Scorri
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
    </div>
    <div class="chip-scroll-wrapper relative">
      <div class="chip-scroll-fade-left"></div>
      <div class="chip-scroll-fade-right"></div>
      <div class="flex gap-3 overflow-x-auto pb-4 px-4 sm:px-0 snap-x snap-mandatory drag-source-container chip-scroll-container" style="-webkit-overflow-scrolling: touch;">
        {items.map((item, i) => (
          <div 
            class="draggable-chip flex items-center gap-2.5 px-3.5 py-2 rounded-xl bg-[var(--bg-input)] border border-[var(--border-card)] cursor-grab hover:border-[#0066FF]/50 hover:shadow-[0_0_15px_rgba(0,102,255,0.2)] transition-all shrink-0 select-none snap-start" 
            draggable="true" 
            data-id={item.id}
          >
            <img src={item.logo} alt={item.nome} class="w-6 h-6 rounded-md bg-[var(--bg-card)] border border-[var(--border-card)] p-0.5 object-cover shrink-0" draggable="false" />
            <div class="flex flex-col">
              <span class="text-sm font-bold text-[var(--text-heading)] whitespace-nowrap leading-none mb-0.5">{item.nome}</span>
              {item.categoria_badge && <span class="text-[9px] font-black uppercase tracking-widest text-[var(--text-muted)] leading-none">{item.categoria_badge}</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 compare-slots-container">
    <div class="compare-slot relative min-h-[300px] rounded-2xl bg-[var(--bg-card)] border-2 border-dashed border-[var(--border-card)] hover:border-[#0066FF]/40 transition-colors flex flex-col" data-slot="0">
       <div class="absolute inset-0 flex flex-col items-center justify-center text-[var(--text-muted)] pointer-events-none slot-placeholder">
         <svg class="w-8 h-8 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
         <span class="text-sm font-medium">Trascina Qui</span>
       </div>
       <div class="slot-content hidden flex-col p-4 space-y-4 h-full relative z-10 w-full animate-fade-in"></div>
    </div>
    
    <div class="compare-slot relative min-h-[300px] rounded-2xl bg-[var(--bg-card)] border-2 border-dashed border-[var(--border-card)] hover:border-[#0066FF]/40 transition-colors flex flex-col" data-slot="1">
       <div class="absolute inset-0 flex flex-col items-center justify-center text-[var(--text-muted)] pointer-events-none slot-placeholder">
         <svg class="w-8 h-8 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
         <span class="text-sm font-medium">Trascina Qui</span>
       </div>
       <div class="slot-content hidden flex-col p-4 space-y-4 h-full relative z-10 w-full animate-fade-in"></div>
    </div>

    <div class="compare-slot relative min-h-[300px] rounded-2xl bg-[var(--bg-card)] border-2 border-dashed border-[var(--border-card)] hover:border-[#0066FF]/40 transition-colors flex flex-col hidden lg:flex" data-slot="2">
       <div class="absolute inset-0 flex flex-col items-center justify-center text-[var(--text-muted)] pointer-events-none slot-placeholder">
         <svg class="w-8 h-8 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
         <span class="text-sm font-medium">Trascina Qui</span>
       </div>
       <div class="slot-content hidden flex-col p-4 space-y-4 h-full relative z-10 w-full animate-fade-in"></div>
    </div>
  </div>

  <style>
    .draggable-chip.dragging {
      opacity: 0.5;
      transform: scale(0.95);
    }
    .compare-slot.drag-over {
      border-color: #0066FF;
      background-color: rgba(0, 102, 255, 0.05);
    }
    .animate-fade-in {
      animation: fadeIn 0.3s ease-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Chip scroll container */
    .chip-scroll-wrapper {
      position: relative;
    }
    .chip-scroll-container {
      scrollbar-width: thin;
      scrollbar-color: var(--scrollbar-thumb) transparent;
    }
    .chip-scroll-container::-webkit-scrollbar {
      height: 6px;
    }
    .chip-scroll-container::-webkit-scrollbar-track {
      background: transparent;
    }
    .chip-scroll-container::-webkit-scrollbar-thumb {
      background: var(--scrollbar-thumb);
      border-radius: 10px;
    }
    .chip-scroll-container::-webkit-scrollbar-thumb:hover {
      background: var(--scrollbar-thumb-hover);
    }
    .chip-scroll-fade-left,
    .chip-scroll-fade-right {
      position: absolute;
      top: 0;
      bottom: 6px;
      width: 40px;
      pointer-events: none;
      z-index: 2;
      transition: opacity 0.3s ease;
    }
    .chip-scroll-fade-left {
      left: 0;
      background: linear-gradient(to right, var(--bg-card, rgba(10,10,18,1)), transparent);
      opacity: 0;
    }
    .chip-scroll-fade-right {
      right: 0;
      background: linear-gradient(to left, var(--bg-card, rgba(10,10,18,1)), transparent);
      opacity: 1;
    }
    .chip-scroll-fade-left.visible { opacity: 1; }
    .chip-scroll-fade-right.hidden { opacity: 0; }
  </style>

  <script is:inline>
    // Usa un wrapper per essere compatibile col router Astro
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.compare-module').forEach((moduleEl) => {
        // Parse data
        if (moduleEl.dataset.initialized === 'true') return;
        moduleEl.dataset.initialized = 'true';
        
        const items = JSON.parse(moduleEl.dataset.items || '[]');
        const fields = JSON.parse(moduleEl.dataset.fields || '[]');
        const itemsMap = new Map(items.map(i => [i.id, i]));
        
        const chips = moduleEl.querySelectorAll('.draggable-chip');
        const slots = moduleEl.querySelectorAll('.compare-slot');
        
        // Scroll fade indicators
        const scrollContainer = moduleEl.querySelector('.chip-scroll-container');
        const fadeLeft = moduleEl.querySelector('.chip-scroll-fade-left');
        const fadeRight = moduleEl.querySelector('.chip-scroll-fade-right');
        
        function updateScrollFades() {
          if (!scrollContainer || !fadeLeft || !fadeRight) return;
          const sl = scrollContainer.scrollLeft;
          const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
          fadeLeft.classList.toggle('visible', sl > 10);
          fadeRight.classList.toggle('hidden', sl >= maxScroll - 10);
        }
        
        if (scrollContainer) {
          scrollContainer.addEventListener('scroll', updateScrollFades, { passive: true });
          // Initial check
          setTimeout(updateScrollFades, 100);
        }
        
        let draggedId = null;

        chips.forEach(chip => {
           chip.addEventListener('click', () => {
              if (window.innerWidth >= 1024) return; // Su mobile o tablet click to add
              const id = chip.dataset.id;
              if(!id) return;
              
              let emptySlot = null;
              for(let i=0; i<slots.length; i++) {
                 if (getComputedStyle(slots[i]).display === 'none') continue;
                 const slotContent = slots[i].querySelector('.slot-content');
                 if (slotContent && slotContent.classList.contains('hidden')) {
                    emptySlot = slots[i];
                    break;
                 }
              }
              if(emptySlot) renderItemInSlot(id, emptySlot);
           });
           
           chip.addEventListener('dragstart', (e) => {
             draggedId = chip.dataset.id || null;
             chip.classList.add('dragging');
             if (e.dataTransfer) {
                e.dataTransfer.effectAllowed = 'copyMove';
                e.dataTransfer.setData('text/plain', draggedId || '');
             }
           });
           
           chip.addEventListener('dragend', () => {
             chip.classList.remove('dragging');
             draggedId = null;
           });
        });

        slots.forEach(slot => {
          slot.addEventListener('dragover', (e) => {
            e.preventDefault();
            if(e.dataTransfer) e.dataTransfer.dropEffect = 'copy';
            slot.classList.add('drag-over');
          });

          slot.addEventListener('dragleave', () => {
            slot.classList.remove('drag-over');
          });

          slot.addEventListener('drop', (e) => {
            e.preventDefault();
            slot.classList.remove('drag-over');
            
            const id = e.dataTransfer ? e.dataTransfer.getData('text/plain') : draggedId;
            if(!id) return;
            
            renderItemInSlot(id, slot);
          });
        });

        function renderItemInSlot(id, slot) {
           const item = itemsMap.get(id);
           if(!item) return;

           const placeholder = slot.querySelector('.slot-placeholder');
           const content = slot.querySelector('.slot-content');
           
           const escapeHTML = (str) => {
              if (typeof str !== 'string') return str;
              return str.replace(/[&<>'"]/g, function (s) {
                 const entityMap = { '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' };
                 return entityMap[s];
              });
           };

           const safeNome = escapeHTML(item.nome);
           const safeLogo = escapeHTML(item.logo);
           const safeCat = item.categoria_badge ? escapeHTML(item.categoria_badge) : '';
           const safeLink = escapeHTML(item.link);

           if(placeholder) placeholder.style.display = 'none';
           
           let html = `
             <div class="flex justify-between items-start mb-2 border-b border-[var(--border-card)] pb-3 shrink-0">
                <div class="flex items-center gap-2.5">
                   <img src="${safeLogo}" alt="${safeNome}" class="w-8 h-8 rounded-lg outline outline-1 outline-[var(--border-card)] object-cover bg-[var(--bg-card)] p-0.5 shrink-0" />
                   <div class="flex flex-col">
                     <h4 class="font-bold text-[var(--text-heading)] leading-tight mb-0.5">${safeNome}</h4>
                     ${safeCat ? `<span class="text-[10px] font-black uppercase tracking-widest text-[#0066FF] bg-[#0066FF]/10 px-1.5 py-0.5 rounded w-fit">${safeCat}</span>` : ''}
                   </div>
                </div>
                <button class="remove-btn text-slate-500 hover:text-red-400 p-1" title="Rimuovi">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
             </div>
             <div class="flex-grow space-y-4 overflow-y-auto hide-scrollbar text-[13px] md:text-sm">
           `;

           fields.forEach((f) => {
              const val = item[f.key];
              if(!val) return;
              const safeLabel = escapeHTML(f.label);

              html += `<div class="flex flex-col gap-1.5 p-2.5 rounded-xl bg-[var(--bg-card)] border border-[var(--border-card)]">
                 <span class="text-[11px] font-bold tracking-widest uppercase text-[var(--text-muted)] shadow-sm">${safeLabel}</span>`;
                 
              if (f.type === 'badge') {
                 html += `<span class="font-semibold text-[#0066FF] px-2 py-1 rounded-lg bg-[#0066FF]/10 w-fit border border-[#0066FF]/20 text-xs">${escapeHTML(String(val))}</span>`;
              } else if (f.type === 'list' && Array.isArray(val)) {
                 html += `<ul class="space-y-1.5 text-[var(--text-body)] mt-1">`;
                 val.forEach((v) => {
                    html += `<li class="flex items-start gap-1.5">
                      <svg class="w-3.5 h-3.5 text-[#03a66d] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      <span class="leading-tight">${escapeHTML(String(v))}</span>
                    </li>`;
                 });
                 html += `</ul>`;
              } else {
                 html += `<span class="text-[var(--text-body)] leading-relaxed font-medium">${escapeHTML(String(val))}</span>`;
              }
              html += `</div>`;
           });

           html += `</div><a href="${safeLink}" target="_blank" rel="noopener noreferrer" class="mt-4 w-full text-center py-2.5 rounded-xl border border-[var(--border-card)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] text-sm font-bold text-[var(--text-heading)] transition-colors shrink-0">Sito Ufficiale ➔</a>`;

           content.innerHTML = html;
           content.classList.remove('hidden');

           const removeBtn = content.querySelector('.remove-btn');
           if(removeBtn) {
              removeBtn.addEventListener('click', () => {
                 content.classList.add('hidden');
                 content.innerHTML = '';
                 if(placeholder) placeholder.style.display = 'flex';
              });
           }
        }
      });
    });
  </script>
</div>
