---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = Astro.props.canonicalURL || new URL(Astro.url.pathname, Astro.site || 'https://privacy-crypto.com').href;
const socialImageURL = new URL(image, Astro.site || 'https://privacy-crypto.com').href;
---

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | Italian Privacy Toolkit`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={`${title} | Italian Privacy Toolkit`} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />
