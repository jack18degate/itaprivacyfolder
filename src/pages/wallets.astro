---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import Accordion from '../components/Accordion.astro';
import CompareModule from '../components/CompareModule.astro';
import data from '../data/wallets.json';

const allWallets = [
  ...data.hardware_wallets.map(w => ({...w, id: 'hw-'+w.nome.replace(/\s+/g, '-'), categoria_badge: 'Hardware Wallet'}), ),
  ...data.hot_wallets.map(w => ({...w, id: 'hot-'+w.nome.replace(/\s+/g, '-'), categoria_badge: 'Hot Wallet (App)'}))
];

const walletFields = [
  { key: 'tipo', label: 'Tipologia', type: 'text' },
  { key: 'chain', label: 'Reti Supportate', type: 'text' },
  { key: 'pro', label: 'Pro', type: 'list' }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faq.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta
    }
  }))
};
---

<Layout title={data.page_title} description="Confronta i migliori hardware e hot wallet per proteggere le tue crypto. Guida completa alla self-custody e seed phrase." maxWidth="max-w-[1300px] xl:max-w-[1400px]">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[#0a0a12]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Indice della Guida</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#hardware" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">Hardware Wallets<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#hot" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">Hot Wallets<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">F.A.Q.<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
         </nav>
       </div>
    </div>

    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
    <div class="inline-block px-3 py-1 mb-3 border border-[#0066FF]/20 bg-[#0066FF]/10 rounded-full text-xs font-bold tracking-wider text-[#0066FF] uppercase">Directory</div>
    <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{data.page_title}</h1>
    <div class="bg-white/[0.02] border border-white/[0.06] p-5 md:p-6 rounded-2xl relative overflow-hidden">
      <div class="absolute left-0 top-0 w-1 h-full bg-[#0066FF]"></div>
      <h3 class="text-white font-bold text-base mb-2.5 flex items-center gap-2"><svg class="w-4 h-4 text-[#0066FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Come scegliere la categoria giusta?</h3>
      <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed">
        Usa gli <strong class="text-white">Hardware Wallet</strong> (es. Trezor, Ledger) come una cassaforte a lungo termine: sono chiavette fisiche che tengono i tuoi soldi offline e al riparo da qualsiasi virus o hacker. Utilizza invece gli <strong class="text-white">Hot Wallet</strong> (es. Rabby, Phantom) come il "portafoglio per tutti i giorni" sul tuo smartphone o browser: perfetti per fare compravendite veloci o interagire col Web3, ma dove non andrebbero mai tenuti i risparmi vitali della propria vita.
      </p>
    </div>

  </header>

  <div class="mb-4 bg-[#03a66d]/5 border border-[#03a66d]/20 p-5 md:p-6 rounded-2xl relative overflow-hidden">
    <div class="absolute right-0 top-0 w-32 h-32 bg-[#03a66d]/10 blur-3xl pointer-events-none rounded-full"></div>
    <h3 class="text-[#03a66d] text-sm md:text-base font-black uppercase tracking-widest mb-2 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      La Regola d'Oro: Seed Phrase Setup
    </h3>
    <p class="text-sm md:text-[15px] text-slate-300 leading-relaxed font-medium">
      I tuoi fondi <strong class="text-white underline decoration-white/30 decoration-2 underline-offset-2">NON vivono dentro il portafoglio hardware.</strong> Le criptovalute esistono unicamente sulla Blockchain. Il wallet (sia fisico che software) è solo un telecomando che "legge" la password (Seed Phrase). 
      <br><br>Se perdi il dispostivo Hardware (Trezor, Ledger), se si brucia in un incendio o se si rompe, <strong class="text-[#03a66d]">i tuoi soldi sono al 100% al sicuro</strong>. Ti basterà comprare un qualsiasi dispositivo nuovo, inserire le famose <strong class="text-white">12 o 24 parole del backup (Seed Phrase)</strong>, precedentemente trascritte con accuratezza su un foglio di carta, e riavrai accesso immediato al totale capitale. Non condividere mai questa sequenza con nessuno, e mai digitalmente.
      <br><br><a href="https://medium.com/degate/generare-una-seed-phrase-usando-i-dadi-42a6632bcd3f" target="_blank" rel="noopener noreferrer" class="text-[#03a66d] underline hover:text-white transition-colors">Leggi la guida: Generare una Seed Phrase usando i dadi</a>
    </p>
  </div>

  <CompareModule items={allWallets} fields={walletFields} tableTitle="Confronto Interattivo Wallet" />



    <section id="faq" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 px-1">Domande Frequenti (F.A.Q)</h2>
      <div class="space-y-3">
        {data.faq.map((item) => (
            <Accordion title={item.domanda}>
              <p class="text-[15px] font-medium leading-relaxed" set:html={item.risposta}></p>
            </Accordion>
        ))}
      </div>
    </section>
  </div>
        </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
