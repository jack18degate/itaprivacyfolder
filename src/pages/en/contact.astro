---
import Layout from '../../layouts/Layout.astro';

const page_title = "Contact & Inquiries";
const page_description = "How to contact the editorial team at privacy-crypto.com for questions, reports, or partnership inquiries.";
---

<Layout title={page_title} description={page_description} maxWidth="max-w-3xl" lang="en">
  <header class="mb-8 border-b border-white/[0.05] pb-6">
    <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-4 text-white">Contact</h1>
    <p class="text-slate-400 text-lg leading-relaxed">{page_description}</p>
  </header>

  <div class="prose prose-invert prose-slate max-w-none">
    <div class="bento-card p-6 border border-white/[0.05] bg-white/[0.02]">
        <p class="text-slate-300 mb-6">
            Privacy Toolkit is a hub of independent resources and does not provide direct services. However, we are open to communications regarding:
        </p>
        
        <ul class="space-y-3 text-slate-400 mb-8 list-none pl-0">
            <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#0066FF] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span><strong>Error reporting:</strong> Found a broken link or outdated information? Let us know.</span>
            </li>
            <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#0066FF] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span><strong>Editorial requests:</strong> Suggestions for new guides or topics you would like to see covered on the site.</span>
            </li>
            <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#0066FF] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span><strong>Technical partnerships:</strong> Are you the founder of an open-source or privacy-focused tool? We evaluate inclusion in our directory, subject to technical verification and independent DYOR.</span>
            </li>
        </ul>

        <h3 class="text-xl font-bold text-white mt-8 mb-4">How to Reach Us</h3>
        <p class="text-slate-400 mb-6">
            You can send an email to the official editorial address. We typically respond within 48–72 business hours.
        </p>
        
        <div class="flex items-center gap-3 p-4 bg-[#0066FF]/5 border border-[#0066FF]/20 rounded-xl w-fit">
            <svg class="w-5 h-5 text-[#0066FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:info@privacy-crypto.com" class="text-white font-bold hover:text-[#0066FF] transition-colors">info@privacy-crypto.com</a>
        </div>

        <p class="text-sm text-red-400 mt-8 italic border-t border-white/[0.05] pt-4">
            Important Notice: Do not write to us asking for advice on how to evade taxes, how to bypass KYC checks, or for financial advice ("which coin to buy"). Such emails will be ignored and immediately deleted.
        </p>
    </div>
  </div>
</Layout>
