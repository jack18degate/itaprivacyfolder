// FAQ data
const faqItems = [
  {
    question: "What is MiCA regulation and why does it matter?",
    answer: "MiCA (Markets in Crypto-Assets Regulation, EU 2023/1114) is the European Union's comprehensive regulatory framework for crypto-asset service providers. Since <strong>June 30, 2025</strong>, all crypto exchanges operating in Europe must obtain authorization from a national competent authority. MiCA establishes uniform rules across all EU member states for consumer protection, market integrity, and financial stability. If an exchange is not MiCA-authorized, it <strong>cannot legally operate</strong> in Europe."
  },
  {
    question: "Which crypto exchanges are MiCA-compliant in Europe?",
    answer: `As of ${lastUpdated}, <strong>${totalProviders} crypto-asset service providers</strong> are officially registered in the ESMA (European Securities and Markets Authority) register. This page lists all of them with daily automatic updates. Major names include Revolut, eToro, Bitpanda, Bybit, Kraken, and many others. Use the table above to search and filter by country or service.`
  },
  {
    question: "Can I use a non-MiCA exchange in Europe?",
    answer: "Technically, some non-authorized exchanges may still be accessible, but they operate <strong>outside European law</strong>. Using them means: no consumer protection, no fund recovery guarantees, and potential legal issues. After June 30, 2025, non-MiCA platforms cannot legally solicit European customers. If something goes wrong (hack, insolvency, frozen funds), you have no legal recourse within EU jurisdiction."
  },
  {
    question: "What's the difference between MiCA, MiFID II, and PSD2?",
    answer: "<strong>MiCA</strong> (Markets in Crypto-Assets) is the mandatory license for any crypto exchange operating in Europe — it covers custody, trading, exchange, and transfer of crypto-assets. <strong>MiFID II</strong> (Markets in Financial Instruments Directive) is for traditional investment services like stocks and derivatives — some CEX obtain it to offer regulated financial products. <strong>PSD2</strong> (Payment Services Directive) is for payment services like bank transfers and cards — needed by exchanges that also offer banking features."
  },
  {
    question: "Does a MiCA-compliant exchange protect my privacy?",
    answer: "No, quite the opposite. MiCA-compliant exchanges are <strong>legally obligated</strong> to implement full KYC (Know Your Customer), collect your personal data (ID, selfie, proof of residence), and under <strong>DAC8</strong> regulation, automatically report all your transactions to your country's tax authority. A regulated CEX is the <strong>worst choice for financial privacy</strong>. If privacy matters to you, consider decentralized exchanges (DEX) and self-custody wallets."
  },
  {
    question: "What happens if I use an unregulated exchange?",
    answer: "Using an unregulated exchange carries several risks: <strong>1)</strong> No consumer protection — if the platform gets hacked or goes bankrupt, your funds are gone. <strong>2)</strong> No legal recourse — you cannot file complaints with European regulators. <strong>3)</strong> Potential legal consequences — depending on your country, using unlicensed platforms may have tax or compliance implications. <strong>4)</strong> Higher scam risk — unregulated platforms have no oversight requirements."
  },
  {
    question: "How can I verify if an exchange is MiCA-authorized?",
    answer: `You can verify directly on the <a href="https://www.esma.europa.eu/databases-library/registers-and-data/crypto-assets-register" target="_blank" rel="noopener noreferrer" class="text-[#0066FF] hover:underline">official ESMA register</a>. This page mirrors that data with daily automatic updates. Check that the exchange has <strong>active authorization status</strong>, verify which EU countries it's passported to operate in, and confirm the specific services it's authorized to provide.`
  },
  {
    question: "Is Binance MiCA-compliant?",
    answer: `Binance's situation in Europe is complex. Check the table above for the current status. Binance has been <a href="/en/guide/binance-micar-self-custody-wallet/" class="text-[#0066FF] hover:underline">pushing users to move to self-custody wallets</a> in some jurisdictions. If you're using Binance, verify that your specific entity is authorized in your country. Regardless of MiCA status, remember that any centralized exchange requires full KYC and reports your data to tax authorities.`
  }
];

// Structured data - FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "en",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

// Structured data - Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/en/" },
    { "@type": "ListItem", "position": 2, "name": "Exchanges", "item": "https://privacy-crypto.com/en/exchange/" },
    { "@type": "ListItem", "position": 3, "name": "MiCA-Compliant Crypto Exchanges" }
  ]
};
---

<Layout title="MiCA-Compliant Crypto Exchanges in Europe" description="Complete and daily-updated list of MiCA-authorized crypto exchanges (EU 2023/1114) from the official ESMA register. Check which platforms are legal in Europe." maxWidth="max-w-[1300px] xl:max-w-[1400px]" lang="en">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar Navigation Left -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[var(--bg-sidebar)]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Page Index</h4>
          <nav class="flex flex-col space-y-3.5">
            <a href="#mica-info" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               MiCA Regulation
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="#exchange-cards" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               Top Exchanges
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="#mica-table" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               ESMA Register
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               F.A.Q.
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="/en/exchange/" class="text-sm text-[#0066FF] hover:text-[#0066FF] font-bold flex items-center justify-between group transition-colors mt-2">
               → Exchange CEX vs DEX
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
         </nav>
       </div>
    </div>

    <!-- Main Content Right -->
    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
        <div class="inline-block px-3 py-1 mb-3 border border-amber-500/20 bg-amber-500/10 rounded-full text-xs font-bold tracking-wider text-amber-500 uppercase">Official Register</div>
        <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">MiCA-Compliant Crypto Exchanges in Europe</h1>
        <div class="p-4 lg:p-5 bg-[var(--bg-sidebar)] border-l-[3px] border-[#0066FF] rounded-r-xl">
          <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">Since <strong class="text-white">June 30, 2025</strong>, under EU Regulation 2023/1114 (MiCA), all crypto-asset service providers must be authorized by national competent authorities. This page lists the <strong class="text-white">officially authorized exchanges</strong> from the ESMA register, updated daily.</p>
        </div>
      </header>

      <!-- Privacy Warning Banner -->
      <section class="scroll-mt-24">
        <div class="bento-card p-5 md:p-7 border-red-500/30 bg-gradient-to-br from-red-900/15 to-red-900/5 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 rounded-full bg-red-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 rounded-full bg-red-500/5 translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
          <div class="relative z-10">
            <h2 class="text-xl md:text-2xl font-bold text-red-400 mb-3.5 flex items-center gap-2">
              <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              ⚠️ A CEX Remains the Worst Choice for Your Privacy
            </h2>
            <p class="text-slate-350 text-[16px] leading-relaxed mb-4.5">Using a Centralized Exchange means <strong class="text-white font-bold">voluntarily surrendering your financial identity</strong> to a private company that is <strong class="text-white font-bold">legally obligated</strong> to share it with tax authorities across Europe.</p>
            <ul class="space-y-3 text-[15px] text-slate-350 mb-4.5">
              <li class="flex items-start gap-2.5">
                <svg class="w-4.5 h-4.5 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span><strong class="text-white font-bold">Full KYC:</strong> ID documents, selfie, proof of residence, bank verification — they know exactly who you are.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="w-4.5 h-4.5 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span><strong class="text-white font-bold">DAC8 Reporting:</strong> Every transaction, deposit and withdrawal is automatically reported to your country's tax authority.</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="w-4.5 h-4.5 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span><strong class="text-white font-bold">Custodial:</strong> You don't own your private keys. The company can freeze, seize or lose your funds at any time (remember FTX?).</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="w-4.5 h-4.5 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span><strong class="text-white font-bold">Profiling:</strong> Your trading patterns, habits and volumes are analyzed and can be shared with third parties.</span>
              </li>
            </ul>
            <div class="bg-black/30 rounded-xl p-4.5 border border-red-500/10">
              <p class="text-[15px] text-slate-300 leading-relaxed">If you <strong>must</strong> use a CEX, at least make sure it's MiCA-regulated. This registry helps you verify that. But remember: <strong class="text-white font-bold">true financial freedom lies in DEX and self-custody</strong>.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- What MiCA Means for You - EU Regulation Cards -->
      <section id="mica-info" class="scroll-mt-24">
        <div class="mb-6">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">What MiCA Means for You</h2>
          <p class="text-slate-400 text-sm">The 3 European licenses that govern crypto-asset services</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
          <!-- MiCA Card -->
          <div class="bento-card p-5.5 border-[#0066FF]/20 bg-gradient-to-br from-[#0066FF]/8 to-transparent relative overflow-hidden">
            <div class="absolute top-0 right-0 w-20 h-20 rounded-full bg-[#0066FF]/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-2.5 mb-3.5">
                <div class="w-10 h-10 rounded-lg bg-[#0066FF]/15 border border-[#0066FF]/30 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-[#0066FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-bold text-[17px]">MiCA</h4>
                  <span class="text-[12px] text-[#0066FF] font-bold uppercase tracking-wider">Essential</span>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">The fundamental license. Without MiCA, an exchange <strong class="text-white font-bold">cannot legally operate</strong> in Europe from 2025. Covers custody, exchange, order execution and crypto-asset transfers.</p>
            </div>
          </div>

          <!-- MiFID II Card -->
          <div class="bento-card p-5.5 border-purple-500/15 bg-gradient-to-br from-purple-900/8 to-transparent relative overflow-hidden">
            <div class="absolute top-0 right-0 w-20 h-20 rounded-full bg-purple-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-2.5 mb-3.5">
                <div class="w-10 h-10 rounded-lg bg-purple-500/15 border border-purple-500/30 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-bold text-[17px]">MiFID II</h4>
                  <span class="text-[12px] text-purple-400 font-bold uppercase tracking-wider">Investments</span>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">For traditional investment services (stocks, derivatives). Some CEX obtain it to offer regulated financial products beyond crypto.</p>
            </div>
          </div>

          <!-- PSD2 Card -->
          <div class="bento-card p-5.5 border-orange-500/15 bg-gradient-to-br from-orange-900/8 to-transparent relative overflow-hidden">
            <div class="absolute top-0 right-0 w-20 h-20 rounded-full bg-orange-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-2.5 mb-3.5">
                <div class="w-10 h-10 rounded-lg bg-orange-500/15 border border-orange-500/30 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-bold text-[17px]">PSD2</h4>
                  <span class="text-[12px] text-orange-400 font-bold uppercase tracking-wider">Payments</span>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">For payment services (bank transfers, cards). Required for exchanges that also offer banking and payment services.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Top Exchanges -->
      <section id="exchange-cards" class="scroll-mt-24">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Top Exchanges: Services & Status</h2>
        <p class="text-[15px] text-slate-500 mb-6 leading-relaxed">Data based on active MiCA and MiFID II licenses. <strong class="text-slate-400 font-bold">Swap Crypto-Fiat</strong> = euro↔crypto conversion. <strong class="text-slate-400 font-bold">Perp Trading w/ Leverage</strong> = perpetual derivatives (requires MiFID license).</p>
        
        <!-- License Filter Checkboxes (English) -->
        <div class="flex flex-wrap items-center gap-4 mb-6 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
          <span class="text-xs md:text-sm font-bold text-slate-400 uppercase tracking-wider">Filter by License:</span>
          <div class="flex flex-wrap gap-2.5">
            <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.02] hover:bg-white/[0.04] transition-all cursor-pointer select-none text-slate-350 hover:text-white" id="label-filter-mica">
              <input type="checkbox" id="filter-mica" class="w-4 h-4 rounded border-slate-700 bg-slate-900 accent-[#0066FF] filter-checkbox" />
              <span class="text-sm font-semibold">MiCA</span>
            </label>
            <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.02] hover:bg-white/[0.04] transition-all cursor-pointer select-none text-slate-350 hover:text-white" id="label-filter-mifid">
              <input type="checkbox" id="filter-mifid" class="w-4 h-4 rounded border-slate-700 bg-slate-900 accent-[#0066FF] filter-checkbox" />
              <span class="text-sm font-semibold">MiFID II</span>
            </label>
            <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.02] hover:bg-white/[0.04] transition-all cursor-pointer select-none text-slate-355 hover:text-white" id="label-filter-psd2">
              <input type="checkbox" id="filter-psd2" class="w-4 h-4 rounded border-slate-700 bg-slate-900 accent-[#0066FF] filter-checkbox" />
              <span class="text-sm font-semibold">PSD2</span>
            </label>
          </div>
        </div>

        <div id="featured-no-results" class="hidden p-8 text-center text-slate-500 text-[15px] border border-dashed border-white/[0.05] rounded-xl bg-white/[0.01]">
          No featured exchanges match the selected criteria.
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {featuredExchanges.map(ex => (
            <div class={`featured-card bento-card p-5 md:p-6 relative overflow-hidden transition-all hover:border-white/[0.1] ${ex.status === 'rejected' ? 'border-red-500/20 opacity-60' : ''}`}
                 data-mica={ex.status === 'compliant' ? 'true' : 'false'}
                 data-mifid={ex.hasMiFID ? 'true' : 'false'}
                 data-psd2={ex.hasPSD2 ? 'true' : 'false'}>
              {/* Status badge */}
              <div class="absolute top-3 right-3">
                <span class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold ${ex.status === 'compliant' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-red-500/10 text-red-400 border border-red-500/20'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${ex.status === 'compliant' ? 'bg-emerald-500' : 'bg-red-500'}`}></span>
                  {ex.statusLabel}
                </span>
              </div>
              {/* Header */}
              <div class="flex items-center gap-3.5 mb-3.5 pr-28 sm:pr-36">
                <div class="w-11 h-11 rounded-xl bg-white/[0.04] border border-white/[0.08] flex items-center justify-center text-2xl shrink-0">{ex.logo}</div>
                <div class="min-w-0">
                  <h3 class="text-lg font-bold text-white truncate">{ex.name}</h3>
                  <span class="text-xs text-slate-500 font-medium">{ex.countryFl} {ex.country}</span>
                </div>
              </div>
              {/* Description */}
              <p class="text-sm text-slate-400 mb-3.5 leading-relaxed">{ex.description}</p>
              {/* Service indicators */}
              <div class="grid grid-cols-2 gap-2 mb-3.5">
                <div class={`rounded-lg p-2.5 text-center border ${ex.swapFiat ? 'bg-emerald-500/[0.06] border-emerald-500/15' : 'bg-white/[0.015] border-white/[0.04]'}`}>
                  <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-0.5">Swap Crypto-Fiat</div>
                  <div class={`text-base font-bold ${ex.swapFiat ? 'text-emerald-400' : 'text-slate-600'}`}>{ex.swapFiat ? 'Yes' : 'No'}</div>
                </div>
                <div class={`rounded-lg p-2.5 text-center border ${ex.tradingPerp ? 'bg-blue-500/[0.06] border-blue-500/15' : 'bg-white/[0.015] border-white/[0.04]'}`}>
                  <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-0.5">Trading Perp Leva</div>
                  <div class={`text-base font-bold ${ex.tradingPerp ? 'text-blue-400' : 'text-slate-600'}`}>{ex.tradingPerp ? 'Yes' : 'No'}</div>
                </div>
              </div>
              {/* MiFID badge */}
              <div class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-bold mb-3.5 ${ex.hasMiFID ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' : 'bg-white/[0.02] text-slate-500 border border-white/[0.05]'}`}>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                {ex.mifidLabel}
              </div>
              {/* Fees */}
              {ex.status !== 'rejected' && (
                <div class="grid grid-cols-2 gap-1.5 mb-3.5">
                  <div class="bg-white/[0.02] rounded-md p-1.5 text-center">
                    <div class="text-[10px] text-slate-500 uppercase">Spot Maker</div>
                    <div class="text-sm font-bold text-white">{ex.fees.spotMaker}</div>
                  </div>
                  <div class="bg-white/[0.02] rounded-md p-1.5 text-center">
                    <div class="text-[10px] text-slate-500 uppercase">Spot Taker</div>
                    <div class="text-sm font-bold text-white">{ex.fees.spotTaker}</div>
                  </div>
                  {ex.hasMiFID && (
                    <>
                      <div class="bg-blue-500/[0.03] rounded-md p-1.5 text-center border border-blue-500/10">
                        <div class="text-[10px] text-blue-400/60 uppercase">Deriv. Maker</div>
                        <div class="text-sm font-bold text-blue-400">{ex.fees.derivMaker}</div>
                      </div>
                      <div class="bg-blue-500/[0.03] rounded-md p-1.5 text-center border border-blue-500/10">
                        <div class="text-[10px] text-blue-400/60 uppercase">Deriv. Taker</div>
                        <div class="text-sm font-bold text-blue-400">{ex.fees.derivTaker}</div>
                      </div>
                    </>
                  )}
                </div>
              )}
              {/* Pros */}
              <ul class="space-y-1 mb-3.5">
                {ex.pros.map(p => (
                  <li class="flex items-start gap-1.5 text-[13px] text-slate-350 font-medium">
                    <svg class={`w-3.5 h-3.5 shrink-0 mt-0.5 ${ex.status === 'rejected' ? 'text-red-500' : 'text-emerald-500'}`} fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {p}
                  </li>
                ))}
              </ul>
              {/* Link */}
              {ex.status !== 'rejected' && (
                <a href={ex.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-[#0066FF] hover:text-blue-400 font-bold transition-colors">
                  Visit {ex.name} →
                </a>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Full ESMA Register -->
      <section id="mica-table" class="scroll-mt-24">
        <details class="bento-card p-0 overflow-hidden border-white/[0.04]" id="esma-details">
          <summary class="p-5 md:p-6 cursor-pointer flex items-center justify-between hover:bg-white/[0.02] transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
            <div>
              <h2 class="text-lg font-bold text-white flex items-center gap-2">📋 Full ESMA Register <span class="text-sm font-normal text-slate-500">({totalProviders} exchanges)</span></h2>
              <p class="text-xs text-slate-500 mt-1">Last updated: <span class="text-slate-400 font-semibold">{lastUpdated}</span> — <a href="https://www.esma.europa.eu/databases-library/registers-and-data/crypto-assets-service-providers-registers" target="_blank" rel="noopener noreferrer" class="text-[#0066FF] hover:underline">Source: ESMA</a></p>
            </div>
            <svg class="w-5 h-5 text-slate-500 transition-transform duration-200 shrink-0 ml-4 details-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <!-- Table Header -->
          <div class="p-5 md:p-6 border-t border-white/[0.05]">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-5">
              <div>
                <p class="text-xs text-slate-500">Search and filter among all authorized providers</p>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <!-- Search -->
              <div class="relative">
                <svg class="w-4 h-4 text-slate-500 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input 
                  type="text" 
                  id="mica-search" 
                  placeholder="Search exchange..."
                  class="w-full sm:w-56 pl-10 pr-4 py-2.5 bg-white/[0.04] border border-white/[0.08] rounded-xl text-sm text-slate-300 placeholder-slate-600 focus:outline-none focus:border-[#0066FF]/40 focus:ring-1 focus:ring-[#0066FF]/20 transition-all"
                />
              </div>
              <!-- Country Filter -->
              <select 
                id="mica-country-filter"
                class="px-4 py-2.5 bg-white/[0.04] border border-white/[0.08] rounded-xl text-sm text-slate-300 focus:outline-none focus:border-[#0066FF]/40 appearance-none cursor-pointer pr-8 bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%23666%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22/%3E%3C/svg%3E')] bg-[length:16px] bg-[right_8px_center] bg-no-repeat"
              >
                <option value="">All countries</option>
                {uniqueCountries.map(code => (
                  <option value={code}>{countryNames[code] || code} ({code})</option>
                ))}
              </select>
            </div>
          </div>

            <!-- Service Filter Checkboxes -->
            <div class="flex flex-wrap gap-2.5">
              {allServiceKeys.map(key => (
                <label class="mica-filter-pill cursor-pointer">
                  <input type="checkbox" value={key} class="mica-svc-filter hidden" />
                  <span class="inline-block px-3.5 py-1.5 rounded-full text-[13px] font-semibold border border-white/[0.08] bg-white/[0.03] text-slate-500 hover:border-white/[0.15] hover:text-slate-400 transition-all select-none">
                    {serviceLabels[key]?.en || key}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Provider Count -->
          <div class="px-5 md:px-6 py-3.5 bg-white/[0.01] border-b border-white/[0.03]">
            <p class="text-sm text-slate-500" id="mica-results-count">
              <span class="text-slate-400 font-bold" id="mica-shown-count">{totalProviders}</span> / {totalProviders} exchanges
            </p>
          </div>

          <!-- Table (Desktop) -->
          <div class="hidden md:block overflow-x-auto">
            <table class="w-full text-base" id="mica-table-el">
              <thead>
                <tr class="border-b border-white/[0.05] text-left text-sm text-slate-500 uppercase tracking-wider">
                  <th class="px-6 py-4 font-bold">Exchange</th>
                  <th class="px-4 py-4 font-bold">Country</th>
                  <th class="px-4 py-4 font-bold">Services</th>
                  <th class="px-4 py-4 font-bold">EU Countries</th>
                  <th class="px-4 py-4 font-bold text-right">Authorized</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/[0.03] text-[15px]">
                {providers.map((p) => (
                  <tr class="mica-row hover:bg-white/[0.02] transition-colors" 
                      data-name={`${p.name} ${p.legal_name}`.toLowerCase()} 
                      data-country={p.country}
                      data-services={p.services.join(',')}>
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <img 
                          src={getFaviconUrl(p.website)} 
                          alt="" 
                          class="w-6.5 h-6.5 rounded-md bg-white/[0.05] shrink-0"
                          loading="lazy"
                          onerror="this.style.display='none'"
                        />
                        <div>
                          <a href={p.website} target="_blank" rel="noopener noreferrer" class="text-white font-bold hover:text-[#0066FF] transition-colors">
                            {p.name}
                          </a>
                          {p.name !== p.legal_name && (
                            <p class="text-xs text-slate-500 mt-0.5 leading-tight">{p.legal_name}</p>
                          )}
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <span class="inline-flex items-center gap-1.5 text-slate-300 font-medium">
                        <span class="text-base">{countryFlag(p.country)}</span>
                        {countryNames[p.country] || p.country}
                      </span>
                    </td>
                    <td class="px-4 py-4">
                      <div class="flex flex-wrap gap-1.5">
                        {p.services.slice(0, 4).map(s => (
                          <span class="px-2 py-0.5 rounded text-xs font-semibold bg-[#0066FF]/10 text-[#0066FF]/80 border border-[#0066FF]/15 whitespace-nowrap">
                            {serviceLabels[s]?.en || s}
                          </span>
                        ))}
                        {p.services.length > 4 && (
                          <span class="px-2 py-0.5 rounded text-xs font-semibold bg-white/[0.05] text-slate-500 border border-white/[0.08]">
                            +{p.services.length - 4}
                          </span>
                        )}
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <span class="text-slate-350 font-bold">{p.eu_countries_count || '—'}</span>
                      {p.passported_countries.includes('IT') && (
                        <span class="ml-1 text-xs" title="Operates in Italy">🇮🇹</span>
                      )}
                    </td>
                    <td class="px-4 py-4 text-right text-slate-400 whitespace-nowrap">
                      {p.authorization_date || '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Cards (Mobile) -->
          <div class="md:hidden divide-y divide-white/[0.03]" id="mica-cards-mobile">
            {providers.map((p) => (
              <div class="mica-row p-4.5 hover:bg-white/[0.02] transition-colors" 
                   data-name={`${p.name} ${p.legal_name}`.toLowerCase()} 
                   data-country={p.country}
                   data-services={p.services.join(',')}>
                <div class="flex items-center gap-3.5 mb-3.5">
                  <img 
                    src={getFaviconUrl(p.website)} 
                    alt="" 
                    class="w-9 h-9 rounded-lg bg-white/[0.05] shrink-0"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  />
                  <div class="flex-1 min-w-0">
                    <a href={p.website} target="_blank" rel="noopener noreferrer" class="text-white font-bold text-base hover:text-[#0066FF] transition-colors block truncate">
                      {p.name}
                    </a>
                    <p class="text-xs text-slate-500 truncate">{p.legal_name}</p>
                  </div>
                  <span class="text-base shrink-0">{countryFlag(p.country)}</span>
                </div>
                <div class="flex flex-wrap gap-1.5 mb-2.5">
                  {p.services.slice(0, 3).map(s => (
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-[#0066FF]/10 text-[#0066FF]/80 border border-[#0066FF]/15">
                      {serviceLabels[s]?.en || s}
                    </span>
                  ))}
                  {p.services.length > 3 && (
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-white/[0.05] text-slate-500 border border-white/[0.08]">
                      +{p.services.length - 3}
                    </span>
                  )}
                </div>
                <div class="flex items-center justify-between text-xs text-slate-500">
                  <span>Operates in <strong class="text-slate-400">{p.eu_countries_count}</strong> EU countries</span>
                  <span>{p.authorization_date || '—'}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- No Results -->
          <div id="mica-no-results" class="hidden p-10 text-center text-slate-500 text-sm">
            No exchanges found for the selected filters.
          </div>
        </details>
      </section>

      <!-- F.A.Q. Section -->
      <section id="faq" class="scroll-mt-24">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 px-1">Frequently Asked Questions (FAQ)</h2>
        <div class="space-y-3">
          {faqItems.map((item) => (
            <Accordion title={item.question}>
              <p class="text-[15px] font-medium leading-relaxed" set:html={item.answer}></p>
            </Accordion>
          ))}
        </div>
      </section>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .mica-filter-pill input:checked + span {
    background: rgba(0, 102, 255, 0.15);
    border-color: rgba(0, 102, 255, 0.4);
    color: #0066FF;
  }
  details[open] .details-chevron {
    transform: rotate(180deg);
  }
</style>

<script is:inline>
  // MiCA Registry search, country & service filter
  (function initMicaFilter() {
    function setup() {
      var searchInput = document.getElementById('mica-search');
      var countryFilter = document.getElementById('mica-country-filter');
      var shownCount = document.getElementById('mica-shown-count');
      var noResults = document.getElementById('mica-no-results');
      var serviceCheckboxes = document.querySelectorAll('.mica-svc-filter');

      // Featured exchanges filter
      var filterMica = document.getElementById('filter-mica');
      var filterMifid = document.getElementById('filter-mifid');
      var filterPsd2 = document.getElementById('filter-psd2');

      if (filterMica && filterMifid && filterPsd2) {
        function updateFeaturedFilter() {
          var micaChecked = filterMica.checked;
          var mifidChecked = filterMifid.checked;
          var psd2Checked = filterPsd2.checked;

          var lblMica = document.getElementById('label-filter-mica');
          var lblMifid = document.getElementById('label-filter-mifid');
          var lblPsd2 = document.getElementById('label-filter-psd2');

          if (lblMica) {
            lblMica.classList.toggle('border-amber-500/35', micaChecked);
            lblMica.classList.toggle('bg-amber-500/5', micaChecked);
            lblMica.classList.toggle('text-white', micaChecked);
          }
          if (lblMifid) {
            lblMifid.classList.toggle('border-blue-500/35', mifidChecked);
            lblMifid.classList.toggle('bg-blue-500/5', mifidChecked);
            lblMifid.classList.toggle('text-white', mifidChecked);
          }
          if (lblPsd2) {
            lblPsd2.classList.toggle('border-emerald-500/35', psd2Checked);
            lblPsd2.classList.toggle('bg-emerald-500/5', psd2Checked);
            lblPsd2.classList.toggle('text-white', psd2Checked);
          }

          var cards = document.querySelectorAll('.featured-card');
          var matched = 0;
          cards.forEach(function(card) {
            var hasMica = card.getAttribute('data-mica') === 'true';
            var hasMifid = card.getAttribute('data-mifid') === 'true';
            var hasPsd2 = card.getAttribute('data-psd2') === 'true';

            var match = true;
            if (micaChecked && !hasMica) match = false;
            if (mifidChecked && !hasMifid) match = false;
            if (psd2Checked && !hasPsd2) match = false;

            if (match) {
              card.style.display = '';
              matched++;
            } else {
              card.style.display = 'none';
            }
          });

          var noMatchEl = document.getElementById('featured-no-results');
          if (noMatchEl) {
            noMatchEl.classList.toggle('hidden', matched > 0);
          }
        }

        filterMica.addEventListener('change', updateFeaturedFilter);
        filterMifid.addEventListener('change', updateFeaturedFilter);
        filterPsd2.addEventListener('change', updateFeaturedFilter);
        updateFeaturedFilter();
      }

      if (!searchInput || !countryFilter) return;

      function filterRows() {
        var query = searchInput.value.toLowerCase().trim();
        var country = countryFilter.value;
        var checkedServices = [];
        serviceCheckboxes.forEach(function(cb) {
          if (cb.checked) checkedServices.push(cb.value);
        });
        var rows = document.querySelectorAll('.mica-row');
        var visibleCount = 0;

        rows.forEach(function(row) {
          var name = row.getAttribute('data-name') || '';
          var rowCountry = row.getAttribute('data-country') || '';
          var rowServices = (row.getAttribute('data-services') || '').split(',');

          var matchSearch = !query || name.includes(query);
          var matchCountry = !country || rowCountry === country;
          var matchServices = checkedServices.length === 0 || checkedServices.every(function(s) {
            return rowServices.indexOf(s) !== -1;
          });

          if (matchSearch && matchCountry && matchServices) {
            row.style.display = '';
            if (row.tagName === 'TR') {
              visibleCount++;
            }
          } else {
            row.style.display = 'none';
          }
        });

        if (shownCount) shownCount.textContent = visibleCount;
        if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);
      }

      searchInput.addEventListener('input', filterRows);
      countryFilter.addEventListener('change', filterRows);
      serviceCheckboxes.forEach(function(cb) {
        cb.addEventListener('change', filterRows);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
    document.addEventListener('astro:page-load', setup);
  })();
</script>
