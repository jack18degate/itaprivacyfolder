  { name: 'Bitvavo', logo: '🇳🇱', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: false, mifidLabel: 'Spot Only — Awaiting MiFID', swapFiat: true, tradingPerp: false, description: 'Absolute leader in Euro liquidity. Over 400 crypto/EUR pairs. Max 0.25% fee with no hidden spreads.', fees: { spotMaker: '0.15%', spotTaker: '0.25%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'Netherlands', countryFl: '🇳🇱', website: 'https://bitvavo.com', pros: ['#1 Euro liquidity in the world', 'Max 0.25% fee (no hidden spread)', 'Clean and simple interface'] },
