  { name: 'OKX', logo: '📈', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: true, hasPSD2: false, mifidLabel: 'MiFID License Active', swapFiat: true, tradingPerp: true, description: 'Global giant of future contract volumes. Excellent mobile app. Derivatives on crypto, stocks and integrated finance.', fees: { spotMaker: '0.08%', spotTaker: '0.10%', derivMaker: '0.02%', derivTaker: '0.05%' }, country: 'Malta', countryFl: '🇲🇹', website: 'https://www.okx.com', pros: ['Among the lowest fees', 'Excellent mobile app', 'Derivatives on traditional markets'] },
  { name: 'Backpack', logo: '🎒', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: true, hasPSD2: false, mifidLabel: 'MiFID License Active', swapFiat: true, tradingPerp: true, description: 'Next-generation exchange with MiFID license. Crypto derivatives and traditional stock trading.', fees: { spotMaker: '0.08%', spotTaker: '0.10%', derivMaker: '0.02%', derivTaker: '0.05%' }, country: 'EU', countryFl: '🇪🇺', website: 'https://backpack.exchange', pros: ['MiFID license for derivatives', 'Traditional stock trading', 'Modern ecosystem'] },
