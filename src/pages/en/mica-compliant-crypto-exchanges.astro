  { name: 'eToro', logo: '📊', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: true, mifidLabel: 'Spot Only — Awaiting MiFID', swapFiat: true, tradingPerp: false, description: 'Social trading platform. Copy top performing traders. Also offers stocks and ETFs.', fees: { spotMaker: 'Spread', spotTaker: '1%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'Cyprus', countryFl: '🇨🇾', website: 'https://www.etoro.com', pros: ['Social and Copy Trading', 'Stocks and ETFs included', 'Intuitive interface'] },
  { name: 'Young Platform', logo: '🇮🇹', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: false, mifidLabel: 'Spot Only', swapFiat: true, tradingPerp: false, description: 'Main Italian operator. CASP MiCA license from Consob and Bank of Italy. Integrated tax management.', fees: { spotMaker: 'Spread', spotTaker: '~1.99%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'Italy', countryFl: '🇮🇹', website: 'https://youngplatform.com', pros: ['Italian MiCA license (Consob/BdI)', 'Integrated tax management', '100% Italian support'] },
  { name: 'WhiteBIT', logo: '⬜', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: false, mifidLabel: 'Spot Only — Awaiting MiFID', swapFiat: true, tradingPerp: false, description: 'Fast-growing exchange in Europe. Fully MiCA compliant for crypto purchases and custody.', fees: { spotMaker: '0.10%', spotTaker: '0.10%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'EU', countryFl: '🇪🇺', website: 'https://whitebit.com', pros: ['Low fixed fees', 'Responsive interface', 'Staking available'] },
