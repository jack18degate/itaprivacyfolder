  { name: 'Conio', logo: '🛡️', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: false, mifidLabel: 'Spot Only', swapFiat: true, tradingPerp: false, description: 'Italian platform with multi-signature system for maximum security. Partnered with traditional banks.', fees: { spotMaker: '~1.25%', spotTaker: '~1.25%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'Italy', countryFl: '🇮🇹', website: 'https://conio.com', pros: ['3-of-3 multi-signature custody', 'Banking partners', 'Based in Italy'] },
  { name: 'Binance', logo: '🟡', status: 'rejected' as const, statusLabel: 'Suspended in EU — No MiCA', hasMiFID: false, hasPSD2: false, mifidLabel: 'Services Suspended', swapFiat: false, tradingPerp: false, description: 'The global giant did NOT obtain CASP authorization. Services ceased for European retail users from July 1, 2026.', fees: { spotMaker: 'Suspended', spotTaker: 'Suspended', derivMaker: 'Suspended', derivTaker: 'Suspended' }, country: 'International', countryFl: '🌍', website: 'https://www.binance.com', pros: ['⚠️ SERVICES SUSPENDED IN EUROPE', 'Withdraw funds immediately'] },
