---
import Layout from '../../layouts/Layout.astro';
import Badge from '../../components/Badge.astro';
import Accordion from '../../components/Accordion.astro';
import spendData from '../../data/en/spend.json';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "en",
  "mainEntity": spendData.faq.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": { "@type": "Answer", "text": item.risposta.replace(/<[^>]+>/g, '') }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/en/" },
    { "@type": "ListItem", "position": 2, "name": "Spend Crypto" }
  ]
};

let positionCounter = 1;
const allItems = [];
if (spendData.carte_crypto) { spendData.carte_crypto.forEach(item => { allItems.push({ "@type": "ListItem", "position": positionCounter++, "name": item.nome, "description": item.pro.join(", "), "url": item.link }); }); }
spendData.gift_cards.forEach(item => { allItems.push({ "@type": "ListItem", "position": positionCounter++, "name": item.nome, "description": item.pro.join(", "), "url": item.link }); });
spendData.beni_fisici.forEach(item => { allItems.push({ "@type": "ListItem", "position": positionCounter++, "name": item.nome, "description": item.pro.join(", "), "url": item.link }); });
const itemListSchema = { "@context": "https://schema.org", "@type": "ItemList", "name": "Platforms and services to spend crypto in the real world", "itemListElement": allItems };
---

<Layout title={spendData.page_title} description="How to spend your cryptocurrencies directly through gift cards and real purchases, maintaining financial privacy outside the banking system." maxWidth="max-w-[1300px] xl:max-w-[1400px]" lang="en">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[#0a0a12]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Page Index</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#cards" class="text-sm text-slate-500 hover:text-emerald-400 font-medium flex items-center justify-between group transition-colors">Crypto Cards<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#gift" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">Gift Cards<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#proxy" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">Physical Goods<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">F.A.Q.<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
         </nav>
       </div>
    </div>

    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
    <div class="inline-block px-3 py-1 mb-3 border border-[#0066FF]/20 bg-[#0066FF]/10 rounded-full text-xs font-bold tracking-wider text-[#0066FF] uppercase">Directory</div>
    <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{spendData.page_title}</h1>
    <div class="p-4 lg:p-5 bg-[#0a0a12] border-l-[3px] border-[#0066FF] rounded-r-xl">
      <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{spendData.page_description}</p>
    </div>
  </header>

      <div class="mt-4 mb-4 bg-white/[0.02] border border-white/[0.06] p-5 md:p-6 rounded-2xl relative overflow-hidden">
    <div class="absolute left-0 top-0 w-1 h-full bg-purple-500"></div>
    <h3 class="text-white font-bold text-base mb-2.5 flex items-center gap-2"><svg class="w-4 h-4 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> How to choose the right category?</h3>
    <div class="text-sm md:text-[15px] text-slate-400 leading-relaxed space-y-2">
      <span class="block"><strong class="text-white">Non-Custodial Crypto Card:</strong> Cards that draw directly from your wallet. <a href="/en/guide/crypto-card-differences/" class="text-purple-400 hover:text-purple-300 underline underline-offset-2 font-semibold transition-colors">Read the guide on differences with traditional cards.</a></span>
      <span class="block"><strong class="text-white">Gift Card:</strong> The simplest way. Exit the market by paying in crypto to get a barcode. Use it anonymously at the checkout, completely severing the link between your bank account and your purchases.</span>
      <span class="block"><strong class="text-white">Proxy Buyer (E-commerce):</strong> Essential if you need physical items shipped or want to buy on Amazon. You pay the intermediary in untraceable crypto, and they use their bank accounts to order on Amazon and ship the product to you.</span>
    </div>
  </div>

    <section id="cards" class="scroll-mt-24">
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-white mb-5 px-1 flex items-center gap-3">
        <div class="w-1 h-5 bg-emerald-500 rounded-full"></div>
        Self-Custody Crypto Cards
      </h2>
<div class="lg:hidden text-right text-xs text-slate-500 font-bold uppercase tracking-wider mb-2.5 pr-2 animate-pulse">Scroll right to explore ➔</div>
<div class="flex overflow-x-auto lg:overflow-visible hide-scrollbar lg:grid lg:grid-cols-2 xl:grid-cols-3 gap-6 pb-4 lg:pb-0 snap-x">
        {spendData.carte_crypto.map(el => (
          <div class="bento-card snap-center shrink-0 w-[85vw] sm:w-[400px] lg:w-auto flex flex-col bg-gradient-to-br from-emerald-900/10 to-transparent border-emerald-500/20">
            <div class="flex justify-between items-start mb-5">
              <div class="flex items-center gap-3.5">
                 <img src={el.logo} alt={`Logo ${el.nome}`} width="40" height="40" class="w-10 h-10 rounded-xl border border-white/[0.08] bg-white/[0.03] p-1 shadow-lg" loading="lazy" />
                 <h3 class="text-base md:text-lg font-bold text-white leading-tight">{el.nome}</h3>
              </div>
              <Badge text={el.badge} variant="green" />
            </div>
            <div class="space-y-4 text-sm flex-grow">
              <div class="flex justify-between items-center border-b border-emerald-500/10 pb-3">
                <span class="text-slate-400">KYC Status</span>
                <span class="font-bold text-emerald-400 text-xs bg-emerald-500/10 px-2.5 py-1 rounded-lg">{el.kyc}</span>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-emerald-500/10">
               <ul class="text-slate-500 text-sm space-y-2">
                 {el.pro.map(p => <li class="flex items-start gap-2"><svg class="w-3.5 h-3.5 text-emerald-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>{p}</li>)}
               </ul>
               <a href={el.link} target="_blank" rel="noopener noreferrer" class="mt-5 w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border border-emerald-500/20 bg-emerald-500/5 hover:bg-emerald-500/10 text-sm font-bold text-emerald-400 hover:text-white transition-colors group">
                  Official Website
                  <svg class="w-3.5 h-3.5 opacity-70 group-hover:opacity-100 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
               </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="gift" class="scroll-mt-24 mt-8">
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-white mb-5 px-1 flex items-center gap-3">
        <div class="w-1 h-5 bg-purple-500 rounded-full"></div>
        Gift Cards & Groceries (No Registration)
      </h2>
<div class="lg:hidden text-right text-xs text-slate-500 font-bold uppercase tracking-wider mb-2.5 pr-2 animate-pulse">Scroll right to explore ➔</div>
<div class="flex overflow-x-auto lg:overflow-visible hide-scrollbar lg:grid lg:grid-cols-2 xl:grid-cols-3 gap-6 pb-4 lg:pb-0 snap-x">
        {spendData.gift_cards.map(el => (
          <div class="bento-card snap-center shrink-0 w-[85vw] sm:w-[400px] lg:w-auto flex flex-col bg-gradient-to-br from-purple-900/10 to-transparent border-purple-500/20">
            <div class="flex justify-between items-start mb-5">
              <div class="flex items-center gap-3.5">
                 <img src={el.logo} alt={`Logo ${el.nome}`} width="40" height="40" class="w-10 h-10 rounded-xl border border-white/[0.08] bg-white/[0.03] p-1 shadow-lg" loading="lazy" />
                 <h3 class="text-base md:text-lg font-bold text-white leading-tight">{el.nome}</h3>
              </div>
              <Badge text={el.badge} variant="gray" />
            </div>
            <div class="space-y-4 text-sm flex-grow">
              <div class="flex justify-between items-center border-b border-purple-500/10 pb-3">
                <span class="text-slate-400">KYC Status</span>
                <span class="font-bold text-purple-400 text-xs bg-purple-500/10 px-2.5 py-1 rounded-lg">{el.kyc}</span>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-purple-500/10">
               <ul class="text-slate-500 text-sm space-y-2">
                 {el.pro.map(p => <li class="flex items-start gap-2"><svg class="w-3.5 h-3.5 text-purple-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>{p}</li>)}
               </ul>
               <a href={el.link} target="_blank" rel="noopener noreferrer" class="mt-5 w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border border-purple-500/20 bg-purple-500/5 hover:bg-purple-500/10 text-sm font-bold text-purple-400 hover:text-white transition-colors group">
                  Official Website
                  <svg class="w-3.5 h-3.5 opacity-70 group-hover:opacity-100 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
               </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="proxy" class="scroll-mt-24">
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-white mb-5 px-1 flex items-center gap-3 mt-8">
        <div class="w-1 h-5 bg-[#0066FF] rounded-full"></div>
        Physical Goods & Web Services
      </h2>
<div class="lg:hidden text-right text-xs text-slate-500 font-bold uppercase tracking-wider mb-2.5 pr-2 animate-pulse">Scroll right to explore ➔</div>
<div class="flex overflow-x-auto lg:overflow-visible hide-scrollbar lg:grid lg:grid-cols-2 xl:grid-cols-3 gap-6 pb-4 lg:pb-0 snap-x">
        {spendData.beni_fisici.map(el => (
          <div class="bento-card snap-center shrink-0 w-[85vw] sm:w-[400px] lg:w-auto flex flex-col relative group">
            <div class="flex justify-between items-start mb-5 relative z-10">
              <div class="flex items-center gap-3.5">
                 <img src={el.logo} alt={`Logo ${el.nome}`} width="40" height="40" class="w-10 h-10 rounded-xl border border-white/[0.08] bg-white/[0.03] p-1 shadow-lg" loading="lazy" />
                 <h3 class="text-base md:text-lg font-bold text-white leading-tight">{el.nome}</h3>
              </div>
              <Badge text={el.badge} variant="blue" />
            </div>
            <div class="space-y-4 text-sm flex-grow relative z-10">
              <div class="flex justify-between items-center border-b border-white/[0.05] pb-3">
                <span class="text-slate-400">KYC Status</span>
                <span class="font-bold text-[#0066FF] text-xs uppercase bg-[#0066FF]/10 px-2.5 py-1 rounded-lg">{el.kyc}</span>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white/[0.05] relative z-10">
               <ul class="text-slate-500 text-sm space-y-2">
                 {el.pro.map(p => <li class="flex items-start gap-2"><svg class="w-3.5 h-3.5 text-[#0066FF] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>{p}</li>)}
               </ul>
               <a href={el.link} target="_blank" rel="noopener noreferrer" class="mt-5 w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border border-[#0066FF]/20 bg-[#0066FF]/5 hover:bg-[#0066FF]/10 text-sm font-bold text-[#0066FF] hover:text-white transition-colors group">
                  Official Website
                  <svg class="w-3.5 h-3.5 opacity-70 group-hover:opacity-100 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
               </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="faq" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 px-1">Frequently Asked Questions (FAQ)</h2>
      <div class="space-y-3">
        {spendData.faq.map((item) => (
            <Accordion title={item.domanda}>
              <p class="text-[15px] font-medium leading-relaxed" set:html={item.risposta}></p>
            </Accordion>
        ))}
      </div>
    </section>
  </div>
        </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
</Layout>
