---
import Layout from '../../layouts/Layout.astro';
import data from '../../data/en/communities.json';
---

<Layout title={data.page_title} description="Communities dedicated to financial privacy and cryptocurrencies: Telegram groups and in-person meetups." noindex={true} lang="en">
  <header class="mb-12">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-3 text-white">{data.page_title}</h1>
    <p class="text-slate-400 text-lg max-w-2xl">{data.page_description}</p>
  </header>

  <div class="grid lg:grid-cols-2 gap-12">
    <section>
      <h2 class="text-xl md:text-2xl font-bold text-white mb-6 px-1 flex items-center gap-3">
        <div class="w-2 h-8 bg-[#0066FF] rounded-full"></div>
        <svg class="w-6 h-6 text-[#0066FF]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.62-.2-1.12-.31-1.1-.66.01-.18.27-.36.78-.55 3.05-1.33 5.09-2.21 6.12-2.64 2.91-1.21 3.52-1.42 3.91-1.43.09 0 .28.02.39.11.09.08.12.18.13.25-.01.03-.01.12-.01.14z"/></svg>
        Telegram Groups
      </h2>
      <div class="grid grid-cols-1 gap-4">
        {data.telegram.map(t => (
          <a href={t.link} target="_blank" rel="noopener noreferrer" class="group bento-card cursor-pointer hover:-translate-y-1 hover:border-[#0066FF]/50 hover:shadow-[0_0_30px_-10px_rgba(0,102,255,0.3)] transition-all overflow-hidden relative">
            <div class="absolute right-0 top-0 w-32 h-32 bg-[#0066FF]/10 rounded-full blur-3xl group-hover:bg-[#0066FF]/20 transition-all pointer-events-none"></div>
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-lg font-bold text-white relative z-10">{t.nome}</h3>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-[#0066FF] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </div>
            <p class="text-slate-400 text-sm relative z-10">{t.descrizione}</p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-xl md:text-2xl font-bold text-white mb-6 px-1 flex items-center gap-3">
        <div class="w-2 h-8 bg-orange-500 rounded-full"></div>
        In-Person Meetups
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4">
        {data.meetups.map(m => (
           <div class="bento-card">
             <div class="flex flex-col mb-4">
               <span class="text-xs font-black text-[#03a66d] mb-1 uppercase tracking-widest">{m.citta}</span>
               <h3 class="text-lg font-bold text-white">{m.nome}</h3>
             </div>
             <div class="inline-block bg-white/[0.05] border border-white/[0.1] text-slate-300 px-3 py-1 rounded-full text-xs font-semibold mb-4">
                {m.frequenza}
             </div>
             <p class="text-slate-400 text-sm leading-relaxed">{m.descrizione}</p>
           </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
