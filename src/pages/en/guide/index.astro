---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guide_en');
const sortedGuides = guides.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/en/" },
    { "@type": "ListItem", "position": 2, "name": "Guides & Tutorials" }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Guides & Tutorials",
  "description": "In-depth insights, guides, and tutorials on crypto, privacy, and decentralized finance.",
  "url": "https://privacy-crypto.com/en/guide/",
  "inLanguage": "en",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": sortedGuides.map((guide, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://privacy-crypto.com/en/guide/${guide.id}/`
    }))
  }
};
---

<Layout title="Guides & Tutorials" description="In-depth insights, guides, and tutorials on crypto, privacy, and decentralized finance." lang="en">
  <div class="max-w-4xl mx-auto py-8 lg:py-12">
    <div class="mb-12 text-center reveal">
      <div class="inline-flex items-center justify-center p-3 rounded-2xl bg-blue-500/10 mb-6">
         <svg class="w-8 h-8 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
         </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 mb-6">
        Guides & Tutorials
      </h1>
      <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Practical insights, step-by-step tutorials, and detailed analyses of privacy tools in the crypto world.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {sortedGuides.map((guide, index) => (
        <a href={`/en/guide/${guide.id}`} class="block group reveal" style={`transition-delay: ${index * 100}ms`}>
          <div class="h-full p-6 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:bg-white/[0.04] hover:border-blue-500/30 transition-all duration-300 relative overflow-hidden shadow-lg hover:shadow-blue-500/10">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <div class="relative z-10 flex flex-col h-full">
              <h2 class="text-xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">
                {guide.data.title}
              </h2>
              <p class="text-slate-400 text-sm mb-6 flex-grow leading-relaxed">
                {guide.data.description}
              </p>
              
              <div class="flex items-center justify-between text-xs font-medium text-slate-500 mt-auto pt-4 border-t border-white/[0.05]">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  <span>
                    {guide.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </span>
                </div>
                <div class="flex items-center gap-1 text-blue-400 group-hover:text-emerald-400 transition-colors">
                  <span>Read Guide</span>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </div>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</Layout>
