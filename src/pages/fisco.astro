---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/Accordion.astro';
import fiscoData from '../data/fisco.json';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "it",
  "mainEntity": fiscoData.faq.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/" },
    { "@type": "ListItem", "position": 2, "name": "Fisco & Tasse" }
  ]
};
---

<Layout title={fiscoData.page_title} description="Tutto quello che devi sapere su DAC8, tassazione crypto in Italia al 33%, CRS, e CARF. Come proteggere il tuo capitale legalmente." maxWidth="max-w-[1300px] xl:max-w-[1400px]">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar Navigation Left -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[#0a0a12]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Indice della Guida</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#dichiarazione" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               I Tuoi 3 Obblighi
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="#normative" class="text-sm text-slate-500 hover:text-red-400 font-medium flex items-center justify-between group transition-colors">
               Impatto DAC8 (2026)
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="#fonti" class="text-sm text-slate-500 hover:text-yellow-400 font-medium flex items-center justify-between group transition-colors">
               Riferimenti di Legge
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#03a66d] font-medium flex items-center justify-between group transition-colors">
               F.A.Q. Interattive
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
         </nav>
         
         <div class="mt-8 p-4 bg-[#03a66d]/10 rounded-xl border border-[#03a66d]/20 text-xs text-[#03a66d] font-semibold flex items-start gap-2 leading-relaxed">
            <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            I contenuti presenti sono puramente divulgativi e non costituiscono in alcun modo parere fiscale. Conferma sempre con un commercialista.
         </div>

         <a href="/guide/crypto-card-e-fisco-differenze-tra-carte-custodial/" class="mt-4 block p-4 bg-purple-500/10 rounded-xl border border-purple-500/20 text-xs text-purple-400 font-semibold leading-relaxed hover:bg-purple-500/15 hover:border-purple-500/30 transition-all group">
            <span class="flex items-start gap-2">
              <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              <span>Crypto Card e Fisco: come funzionano le carte non-custodial e cosa cambia per il CRS ➔</span>
            </span>
         </a>
         </div>
      </div>

    <!-- Main Content Right -->
    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
        <div class="inline-block px-3 py-1 mb-3 border border-[#0066FF]/20 bg-[#0066FF]/10 rounded-full text-xs font-bold tracking-wider text-[#0066FF] uppercase">Consultazione Rapida</div>
        <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{fiscoData.hero_question}</h1>
        
        <div class="mb-6 mt-4 p-5 bg-gradient-to-r from-[#0066FF]/20 to-transparent border border-[#0066FF]/30 rounded-xl relative overflow-hidden">
          <div class="absolute right-0 top-0 w-32 h-32 bg-[#0066FF]/10 blur-3xl pointer-events-none rounded-full"></div>
          <div class="relative z-10 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
            <div>
              <h3 class="text-white font-bold text-lg mb-1 flex items-center gap-2">👉 Vuoi capire il DAC8 a fondo?</h3>
              <p class="text-slate-300 text-sm">Dalle fondamenta normative alle implicazioni operative: leggi la nostra guida completa.</p>
            </div>
            <a href="/fisco/dac8-guida-completa/" class="px-5 py-2.5 bg-[#0066FF] hover:bg-[#0055DD] text-white text-sm font-bold rounded-lg transition-colors whitespace-nowrap shrink-0 shadow-lg shadow-[#0066FF]/20">Leggi la Guida ➔</a>
          </div>
        </div>

        <div class="p-4 lg:p-5 bg-[#0a0a12] border-l-[3px] border-[#0066FF] rounded-r-xl">
          <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{fiscoData.hero_answer}</p>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="bento-card p-4 border-[#0066FF]/10 bg-gradient-to-br from-[#0066FF]/5 to-transparent relative overflow-hidden">
          <div class="text-[#0066FF] text-3xl md:text-4xl font-black mb-1">2026</div>
          <div class="text-slate-300 font-bold text-sm">Entrata in vigore DAC8</div>
        </div>
        <div class="bento-card p-4 border-red-500/10 bg-gradient-to-br from-red-500/5 to-transparent relative overflow-hidden">
          <div class="text-red-500 text-3xl md:text-4xl font-black mb-1">33%</div>
          <div class="text-slate-300 font-bold text-sm">Tassazione Plusvalenze</div>
        </div>
        <div class="bento-card p-4 border-[#03a66d]/10 bg-gradient-to-br from-[#03a66d]/5 to-transparent relative overflow-hidden">
          <div class="text-[#03a66d] text-3xl md:text-4xl font-black mb-1">0,2%</div>
          <div class="text-slate-300 font-bold text-sm">Imposta di Bollo (IVAFE)</div>
        </div>
      </div>
      <section id="dichiarazione" class="scroll-mt-24">
        <h2 class="text-lg md:text-xl font-bold text-white mb-4 px-1 flex items-center gap-2.5 tracking-tight">
          <div class="w-1 h-5 bg-[#0066FF] rounded-full"></div>
          I Tuoi 3 Obblighi Fondamentali
        </h2>
        
        <div class="space-y-3">
          {fiscoData.obblighi_principali.map((item) => (
             <Accordion title={`Fase ${item.step}: ${item.titolo}`}>
                 <div class="mb-3">
                   <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-bold uppercase tracking-widest bg-white/[0.04] text-[#0066FF] border border-white/[0.04]">{item.badge}</span>
                 </div>
                 <p class="text-slate-400 text-[15px] md:text-base leading-relaxed mb-4">{item.descrizione}</p>
                 <div class="bg-[#0a0a12] p-3.5 rounded-xl border border-white/[0.04] text-sm font-medium text-slate-400 flex items-start gap-2.5">
                    <svg class="w-4 h-4 text-[#0066FF] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {item.importante}
                 </div>
             </Accordion>
          ))}
        </div>
      </section>

      <!-- La regola d'oro Crypto-to-Crypto -->
      <section>
        <div class="bento-card bg-gradient-to-br from-green-500/10 to-transparent border-green-500/20 py-5">
          <h2 class="text-base font-bold text-green-400 mb-2">{fiscoData.neutralita_crypto.titolo}</h2>
          <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{fiscoData.neutralita_crypto.spiegazione}</p>
        </div>
      </section>

      <!-- Normative Internazionali / DAC8 -->
      <section id="normative" class="scroll-mt-24">
        <h2 class="text-lg md:text-xl font-bold text-white mb-4 px-1 flex items-center gap-2.5 tracking-tight">
          <div class="w-1 h-5 bg-red-500 rounded-full"></div>
          Orizzonte 2026: L'Ansia DAC8
        </h2>
        <div class="space-y-3">
          {fiscoData.normative.map((item) => (
            <Accordion title={item.titolo}>
              <p class="text-slate-400 text-[15px] md:text-base leading-relaxed mb-4">{item.spiegazione}</p>
              
              {item.video_link && (
                 <a href={item.video_link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 mb-3 bg-red-900/20 hover:bg-red-900/40 border border-red-800/30 rounded-xl text-red-200 hover:text-white text-sm font-bold transition-all w-fit group/video">
                   <svg class="w-4 h-4 text-red-500 group-hover/video:text-red-400 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                   Guarda il Video Prova
                 </a>
              )}

              {item.tooltip_term && (
                <div class="p-3 bg-red-900/10 rounded-xl text-sm border border-red-500/10 mt-2">
                  <span class="font-bold text-red-500">{item.tooltip_term}:</span> <span class="text-slate-500">{item.tooltip_desc}</span>
                </div>
              )}
            </Accordion>
          ))}
        </div>
      </section>

      <!-- Fonti e Riferimenti -->
      <section id="fonti" class="scroll-mt-24 mb-8">
        <Accordion title="Fonti e Gazzetta Ufficiale">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
            {fiscoData.riferimenti_ufficiali.map((item) => (
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="bento-card-interactive group border-yellow-500/10 hover:border-yellow-500/30 flex flex-col">
                <div class="flex items-start justify-between mb-2">
                  <h3 class="text-[15px] font-bold text-slate-200 group-hover:text-yellow-400 transition-colors pr-4">{item.titolo}</h3>
                  <svg class="w-4 h-4 text-slate-600 group-hover:text-yellow-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </div>
                <p class="text-sm text-slate-500 leading-relaxed font-medium">{item.descrizione}</p>
              </a>
            ))}
          </div>
        </Accordion>
      </section>

      <!-- F.A.Q. Interattive -->
      <section id="faq" class="scroll-mt-24">
        <h2 class="text-lg md:text-xl font-bold text-white mb-5 px-1 flex items-center gap-2.5 tracking-tight">
          <div class="w-1 h-5 bg-[#03a66d] rounded-full"></div>
          F.A.Q. Fiscali Complete
        </h2>
        
        <!-- Search Bar -->
        <div class="mb-5 relative">
           <svg class="w-5 h-5 text-slate-500 absolute left-4 top-1/2 transform -translate-y-1/2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
           <input type="text" id="faq-search" placeholder="Cerca un dubbio (es: Ledger, Binance, 2000 euro...)" class="w-full bg-[#0a0a12] border border-white/[0.06] text-slate-300 text-[15px] rounded-2xl pl-12 pr-4 py-3.5 focus:ring-[#0066FF] focus:border-[#0066FF] outline-none transition-all placeholder-slate-700 font-medium" />
        </div>

        <div class="space-y-2.5" id="faq-container">
          {fiscoData.faq.map((item, index) => (
            <div class="faq-item" data-text={item.domanda.toLowerCase() + " " + item.risposta.toLowerCase()}>
               <Accordion title={item.domanda}>
                 <p class="text-[15px] font-normal leading-relaxed text-slate-400" set:html={item.risposta}></p>
               </Accordion>
            </div>
          ))}
          <div id="faq-empty" class="hidden text-center py-10 text-slate-600 text-base font-medium">Nessun dubbio trovato per questa ricerca.</div>
        </div>
      </section>
  </div>
</div>

  <script is:inline>
    // Logica Search Bar FAQ
    document.addEventListener('DOMContentLoaded', () => {
       const searchInput = document.getElementById('faq-search');
       const items = document.querySelectorAll('.faq-item');
       const msgEmpty = document.getElementById('faq-empty');

       if(searchInput) {
         searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            let visibleCount = 0;

            items.forEach(item => {
               const text = item.getAttribute('data-text') || '';
               if(text.includes(query)) {
                  item.style.display = 'block';
                  visibleCount++;
               } else {
                  item.style.display = 'none';
               }
            });

            if(visibleCount === 0) {
               msgEmpty.classList.remove('hidden');
            } else {
               msgEmpty.classList.add('hidden');
            }
         });
       }
    });
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
