---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guide');
  return guides.map(guide => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": guide.data.title,
  "description": guide.data.description,
  "inLanguage": "it",
  "image": "https://privacy-crypto.com/og-image.jpg",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://privacy-crypto.com/guide/${guide.id}/`
  },
  "author": {
    "@type": "Organization",
    "name": guide.data.author
  },
  "datePublished": guide.data.pubDate.toISOString(),
  "dateModified": guide.data.pubDate.toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Privacy Toolkit",
    "logo": {
      "@type": "ImageObject",
      "url": "https://privacy-crypto.com/favicon.svg"
    }
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/" },
    { "@type": "ListItem", "position": 2, "name": "Guide & Tutorial", "item": "https://privacy-crypto.com/guide/" },
    { "@type": "ListItem", "position": 3, "name": guide.data.title }
  ]
};
---

<Layout title={guide.data.title} description={guide.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <article class="max-w-3xl mx-auto py-8 lg:py-16 reveal">
    <a href="/guide/" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-blue-400 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Torna alle Guide
    </a>
    
    <header class="mb-10 pb-10 border-b border-white/[0.05]">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
        {guide.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-slate-400 font-medium">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          {guide.data.pubDate.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
        <span class="text-white/[0.1]">•</span>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          {guide.data.author}
        </div>
      </div>
    </header>

    <div class="prose prose-invert max-w-none 
      prose-p:text-[17px] md:prose-p:text-[19px] prose-p:text-slate-300 prose-p:leading-[1.8] prose-p:mb-8
      prose-headings:font-extrabold prose-headings:tracking-tight 
      prose-h2:text-3xl md:prose-h2:text-4xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:text-white
      prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-6 prose-h3:text-slate-200
      prose-a:text-blue-400 prose-a:no-underline hover:prose-a:text-blue-300 hover:prose-a:underline
      prose-strong:text-white prose-strong:font-bold
      prose-ul:space-y-3 prose-li:text-[17px] md:prose-li:text-[19px] prose-li:text-slate-300 prose-li:leading-[1.8]
      prose-blockquote:bg-white/[0.02] prose-blockquote:border prose-blockquote:border-white/[0.08] prose-blockquote:rounded-2xl prose-blockquote:p-6 md:prose-blockquote:p-8 prose-blockquote:my-10 prose-blockquote:not-italic prose-blockquote:text-slate-200 prose-blockquote:shadow-xl
      prose-hr:border-white/[0.05] prose-hr:my-16
      prose-img:rounded-2xl prose-img:shadow-2xl prose-img:border prose-img:border-white/[0.05]">
      <Content />
    </div>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
