---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import Accordion from '../components/Accordion.astro';
import CompareModule from '../components/CompareModule.astro';
import exData from '../data/exchanges.json';

const allExchangeItems = [
  ...exData.dex.map(e => ({...e, id: 'dex-'+e.nome.replace(/\s+/g, '-'), categoria_badge: 'DEX Onchain'})),
  ...exData.cex.map(e => ({...e, id: 'cex-'+e.nome.replace(/\s+/g, '-'), categoria_badge: 'CEX Tradizionale'}))
];

const exchangeFields = [
  { key: 'kyc', label: 'KYC Status', type: 'badge' },
  { key: 'consigliato', label: 'Consigliato Per', type: 'text' },
  { key: 'pro', label: 'Pro', type: 'list' }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": exData.faq_exchange.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta
    }
  }))
};
---

<Layout title={exData.page_title_exchange} description="Confronta i migliori Exchange Centralizzati (CEX) e Decentralizzati (DEX). Riduci il rischio di controparte e proteggi la tua privacy scambiando crypto in sicurezza." maxWidth="max-w-[1300px] xl:max-w-[1400px]">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar Navigation Left -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[var(--bg-sidebar)]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Indice della Guida</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#intro" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               CEX vs DEX
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>

            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               F.A.Q.
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="/acquisto" class="text-sm text-[#0066FF] hover:text-[#0066FF] font-bold flex items-center justify-between group transition-colors mt-2">
               → Acquisto Crypto
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
         </nav>
       </div>
    </div>

    <!-- Main Content Right -->
    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
    <div class="inline-block px-3 py-1 mb-3 border border-[#0066FF]/20 bg-[#0066FF]/10 rounded-full text-xs font-bold tracking-wider text-[#0066FF] uppercase">Directory</div>
    <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{exData.page_title_exchange}</h1>
    <div class="p-4 lg:p-5 bg-[var(--bg-sidebar)] border-l-[3px] border-[#0066FF] rounded-r-xl">
      <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{exData.page_description_exchange}</p>
    </div>
  </header>

  <!-- Sezione Intro: Differenze CEX vs DEX -->
  <section id="intro" class="scroll-mt-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
      <!-- CEX Card -->
      <div class="bento-card p-5 md:p-6 border-red-500/20 bg-gradient-to-br from-red-900/10 to-transparent relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-red-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-red-500/10 border border-red-500/30 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-lg">CEX — Centralizzato</h3>
              <span class="text-xs text-red-400 font-bold uppercase tracking-wider">Sorvegliato</span>
            </div>
          </div>
          <ul class="space-y-2.5 text-sm text-slate-400">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">KYC Obbligatorio:</strong> Documenti, selfie, verifica bancaria</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">Custodial:</strong> L'azienda detiene le tue chiavi</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">DAC8:</strong> Dati trasmessi automaticamente al fisco</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Pro:</strong> Liquidità immensa, fiat on/off ramp facile</span></li>
          </ul>
        </div>
      </div>

      <!-- DEX Card -->
      <div class="bento-card p-5 md:p-6 border-[#03a66d]/20 bg-gradient-to-br from-[#03a66d]/10 to-transparent relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-[#03a66d]/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#03a66d]/10 border border-[#03a66d]/30 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#03a66d]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-lg">DEX — Decentralizzato</h3>
              <span class="text-xs text-[#03a66d] font-bold uppercase tracking-wider">Privato</span>
            </div>
          </div>
          <ul class="space-y-2.5 text-sm text-slate-400">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Zero KYC:</strong> Nessun documento, nessuna registrazione</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Self-Custody:</strong> Tu controlli le tue chiavi al 100%</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Censorship-Resistant:</strong> Nessuno può bloccare il tuo account</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">Nota:</strong> Solo crypto↔crypto, serve già possedere crypto</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  
  <CompareModule items={allExchangeItems} fields={exchangeFields} tableTitle="Confronto CEX vs DEX" />

  <!-- La Terza Via -->
  <section class="mt-12 mb-12 scroll-mt-24">
    <div class="bento-card p-6 md:p-8 border-[#0066FF]/20 bg-gradient-to-br from-[#0066FF]/5 to-transparent relative overflow-hidden">
      <div class="absolute top-0 right-0 w-40 h-40 rounded-full bg-[#0066FF]/10 blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
      <div class="relative z-10">
        <h3 class="text-xl md:text-2xl font-bold text-white mb-4">La Terza Via — Wallet Self-Custodial con Swap Integrato</h3>
        <p class="text-slate-400 text-[15px] leading-relaxed mb-4">
          I CEX ti espongono al fisco tramite DAC8.<br/>
          I DEX ti danno libertà ma ti lasciano da solo davanti alla complessità di 12 blockchain diverse.<br/>
          Esiste una terza via: un wallet self-custodial con aggregazione Swap cross-chain integrata. I tuoi fondi restano sotto il tuo controllo — quindi fuori dal perimetro DAC8 — ma scambi tra chain con la semplicità di un exchange centralizzato.
        </p>
        <div class="bg-black/30 rounded-xl p-5 border border-white/[0.05]">
          <h4 class="text-[#0066FF] font-bold text-sm uppercase tracking-wider mb-3">Esempio rappresentativo: <a href="https://app.degate.com/it/?s=jack18&utm_source=it_privacy_site&utm_content=exchange" target="_blank" class="hover:underline">DeGate Wallet</a></h4>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-slate-300">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Multi-chain (Ethereum, Solana, BSC, Arbitrum, Base...)</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Gas pagato in USDC</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Zero KYC</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>MPC security</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

    <!-- F.A.Q. Exchange -->
    <section id="faq" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 px-1">Domande Frequenti (F.A.Q)</h2>
      <div class="space-y-3">
        {exData.faq_exchange.map((item) => (
            <Accordion title={item.domanda}>
              <p class="text-[15px] font-medium leading-relaxed" set:html={item.risposta}></p>
            </Accordion>
        ))}
      </div>
    </section>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
