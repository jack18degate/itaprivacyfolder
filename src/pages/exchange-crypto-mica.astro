// FAQ data
const faqItems = [
  {
    domanda: "Cos'è il regolamento MiCA e perché è importante?",
    risposta: `Il <strong class="text-white">MiCA (Markets in Crypto-Assets Regulation)</strong> è il Regolamento UE 2023/1114, il primo quadro normativo organico europeo per i crypto-asset. Entrato pienamente in vigore il <strong class="text-white">30 giugno 2025</strong>, impone a tutti i Crypto-Asset Service Provider (CASP) di ottenere un'autorizzazione da un'autorità nazionale competente (come la CONSOB in Italia o la BaFin in Germania) per operare legalmente nell'Unione Europea. MiCA è importante perché standardizza le regole in tutti i 27 Stati membri, eliminando il patchwork di normative nazionali e garantendo requisiti minimi di trasparenza, protezione dei consumatori e riserve di capitale per gli emittenti di stablecoin.`
  },
  {
    domanda: "Quali exchange sono MiCA compliant in Italia?",
    risposta: `Tra gli exchange più noti che hanno ottenuto la licenza MiCA e operano in Italia tramite passaporto europeo troviamo: <strong class="text-white">Bitpanda</strong> (autorizzato da FMA Austria), <strong class="text-white">Bybit</strong> (autorizzato da FMA Austria), <strong class="text-white">eToro</strong> (autorizzato da CySEC Cipro), <strong class="text-white">Revolut</strong> (autorizzato da CySEC Cipro), <strong class="text-white">Kraken</strong> (autorizzato da CBI Irlanda), <strong class="text-white">KuCoin EU</strong> (autorizzato da FMA Austria), <strong class="text-white">WhiteBIT EU</strong> (autorizzato da FMA Austria) e <strong class="text-white">Trading 212</strong> (autorizzato da CySEC Cipro). La lista completa e aggiornata quotidianamente è disponibile nella tabella sopra, estratta direttamente dal registro ufficiale ESMA.`
  },
  {
    domanda: "Posso usare un exchange non MiCA in Europa?",
    risposta: `Tecnicamente, dal <strong class="text-white">30 giugno 2025</strong>, un provider non autorizzato MiCA <strong class="text-white">non può offrire legalmente servizi crypto</strong> a residenti dell'UE. Le autorità nazionali possono bloccare l'accesso ai siti non autorizzati, congelare fondi e imporre sanzioni. Alcuni exchange non-MiCA potrebbero ancora essere accessibili tramite VPN, ma utilizzarli comporta rischi significativi: nessuna protezione legale per il consumatore, impossibilità di ricorso in caso di controversie e potenziali problemi fiscali, dato che le transazioni su piattaforme non regolamentate possono essere considerate sospette dalle autorità tributarie.`
  },
  {
    domanda: "Qual è la differenza tra MiCA, MiFID II e PSD2?",
    risposta: `Le tre licenze coprono ambiti diversi: <strong class="text-white">MiCA</strong> (Reg. UE 2023/1114) è specifica per i servizi su crypto-asset — custodia, scambio fiat↔crypto e crypto↔crypto, esecuzione ordini, trasferimento e collocamento. <strong class="text-white">MiFID II</strong> (Dir. 2014/65/UE) regola i servizi d'investimento tradizionali come azioni, obbligazioni, derivati e fondi — alcuni exchange la ottengono per offrire prodotti finanziari regolamentati accanto alle crypto. <strong class="text-white">PSD2</strong> (Dir. 2015/2366/UE) disciplina i servizi di pagamento — bonifici, carte, portafogli elettronici — ed è necessaria per gli exchange che offrono anche funzionalità bancarie. Un exchange completo potrebbe avere tutte e tre le licenze.`
  },
  {
    domanda: "Un exchange MiCA-compliant protegge la mia privacy?",
    risposta: `<strong class="text-white">Assolutamente no.</strong> MiCA impone requisiti di <strong class="text-white">KYC (Know Your Customer) obbligatorio</strong>: per usare qualsiasi exchange autorizzato devi fornire documento d'identità, selfie, prova di residenza e spesso anche verifica bancaria. Inoltre, con la direttiva <strong class="text-white">DAC8</strong> (in vigore dal 2026), tutti i CASP autorizzati sono obbligati a trasmettere automaticamente i dati delle transazioni dei clienti alle autorità fiscali di ogni Stato membro. Se la privacy finanziaria è la tua priorità, la soluzione è usare <strong class="text-white">exchange decentralizzati (DEX)</strong> e <strong class="text-white">wallet self-custodial</strong> che non richiedono KYC e non sono soggetti a DAC8.`
  },
  {
    domanda: "Cosa succede se uso un exchange non regolamentato?",
    risposta: `Usare un exchange non autorizzato comporta <strong class="text-white">rischi concreti</strong>: nessuna protezione legale in caso di perdita dei fondi (come avvenuto con FTX, che non era regolamentato nell'UE), impossibilità di fare ricorso presso le autorità di vigilanza nazionali, rischio di frode senza alcun meccanismo di compensazione, potenziali problemi con le autorità fiscali (le transazioni potrebbero essere considerate sospette o non dichiarabili correttamente) e rischio di sequestro dei fondi se l'exchange viene chiuso dalle autorità. Un exchange MiCA offre almeno garanzie di riserve di capitale, segregazione dei fondi e procedure di reclamo obbligatorie.`
  },
  {
    domanda: "Come verifico se un exchange è autorizzato MiCA?",
    risposta: `Puoi verificare l'autorizzazione MiCA di un exchange in due modi: consultando il <a href="https://www.esma.europa.eu/databases-library/registers-and-data/crypto-assets-service-providers-registers" target="_blank" rel="noopener noreferrer" class="text-[#0066FF] hover:underline">registro ufficiale ESMA</a> (European Securities and Markets Authority), che raccoglie tutte le autorizzazioni rilasciate dalle autorità nazionali competenti dei 27 Stati membri, oppure <strong class="text-white">consultando questa pagina</strong>, che estrae e aggiorna quotidianamente i dati direttamente dal registro ESMA, presentandoli in un formato più leggibile e filtrabile. Se un exchange non appare nel registro ESMA, non è autorizzato ad operare nell'UE sotto MiCA.`
  },
  {
    domanda: "Binance è MiCA compliant?",
    risposta: `Al momento dell'ultimo aggiornamento di questa pagina (<strong class="text-white">${lastUpdated}</strong>), <strong class="text-white">Binance non risulta nel registro ufficiale ESMA</strong> come provider autorizzato MiCA. Binance ha avuto un percorso complesso con i regolatori europei: ha ritirato la domanda di licenza in diversi paesi e opera attraverso entità locali con status diversi. È fondamentale verificare sempre il registro ESMA per informazioni aggiornate, poiché la situazione normativa può evolversi. Se stai cercando un exchange MiCA-compliant, consulta la tabella sopra per alternative autorizzate che operano legalmente in Italia e nell'UE.`
  }
];

// Structured data: FAQ schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "it",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta.replace(/<[^>]*>/g, '')
    }
  }))
};

// Structured data: Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/" },
    { "@type": "ListItem", "position": 2, "name": "Exchange", "item": "https://privacy-crypto.com/exchange/" },
    { "@type": "ListItem", "position": 3, "name": "Exchange Crypto Autorizzati MiCA" }
  ]
};
