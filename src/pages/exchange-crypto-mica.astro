  { name: 'Young Platform', logo: '🇮🇹', status: 'compliant' as const, statusLabel: 'MiCA Compliant', hasMiFID: false, hasPSD2: false, mifidLabel: 'Solo Spot', swapFiat: true, tradingPerp: false, description: 'Principale operatore italiano. Licenza CASP MiCA da Consob e Banca d\'Italia. Gestione fiscale integrata.', fees: { spotMaker: 'Spread', spotTaker: '~1.99%', derivMaker: 'N/A', derivTaker: 'N/A' }, country: 'Italia', countryFl: '🇮🇹', website: 'https://youngplatform.com', pros: ['Licenza MiCA italiana (Consob/BdI)', 'Gestione fiscale integrata', 'Assistenza 100% Italia'] },
