---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/Accordion.astro';
import idData from '../data/identity.json';
import vpnData from '../data/vpn.json';

const page_title = "Risorse Varie (Digital ID, VPN, Tool)";
const page_description = "Una collezione di strumenti fondamentali per la tua privacy: identità digitali estere alternative, reti VPN No-Log per navigare in sicurezza, e soluzioni ad alta privacy aggiuntive.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "it",
  "mainEntity": idData.faq.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta.replace(/<[^>]+>/g, '') // Strip HTML for schema
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/" },
    { "@type": "ListItem", "position": 2, "name": "Risorse Varie" }
  ]
};
---

<Layout title={page_title} description="Risorse essenziali per la privacy online: VPN no-log, identità digitali decentralizzate e SIM telefoniche ad alta privacy per proteggere i tuoi dati." maxWidth="max-w-[1300px] xl:max-w-[1400px]">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[#0a0a12]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Indice della Guida</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#id-palau" class="text-sm text-slate-500 hover:text-[#03a66d] font-medium flex items-center justify-between group transition-colors">Palau RNS.ID<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#id-alternative" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">Altre Global ID<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#vpn" class="text-sm text-slate-500 hover:text-red-500 font-medium flex items-center justify-between group transition-colors">Tunnel VPN<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#extra" class="text-sm text-slate-500 hover:text-orange-500 font-medium flex items-center justify-between group transition-colors">Extra & Guide<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-purple-400 font-medium flex items-center justify-between group transition-colors">F.A.Q.<svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
         </nav>
      </div>
    </div>

    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
        <div class="inline-block px-3 py-1 mb-3 border border-[#0066FF]/20 bg-[#0066FF]/10 rounded-full text-xs font-bold tracking-wider text-[#0066FF] uppercase">Directory</div>
        <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{page_title}</h1>
        <div class="p-4 lg:p-5 bg-[#0a0a12] border-l-[3px] border-[#0066FF] rounded-r-xl">
          <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{page_description}</p>
        </div>
      </header>

      <!-- SEZIONE 1: IDENTITÀ DIGITALE -->
      <div class="mb-4">
         <h2 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-tight border-b border-white/[0.1] pb-3">1. Identità Digitali (Palau ID)</h2>
         <p class="text-slate-400 text-sm md:text-[15px] leading-relaxed mt-3">{idData.page_description}</p>
      </div>
      
      <section id="id-palau" class="scroll-mt-24">
        <div class="w-full bento-card p-6 lg:p-10 border border-[#03a66d]/40 bg-gradient-to-br from-[#03a66d]/10 via-transparent to-transparent shadow-[0_0_60px_-15px_rgba(3,166,109,0.4)] relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
             <svg class="w-32 h-32 text-[#03a66d]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
          </div>

          <div class="flex justify-between items-start mb-6 relative z-10">
             <div>
               <div class="inline-block px-3 py-1 bg-[#03a66d]/10 border border-[#03a66d]/30 text-[#03a66d] text-xs font-bold rounded-full uppercase tracking-wider mb-4">Official RNS.ID Program</div>
               <h3 class="text-2xl md:text-3xl font-black text-white mb-3">{idData.hero_info.titolo}</h3>
               <p class="text-slate-400 text-sm md:text-base leading-relaxed max-w-xl">{idData.hero_info.sottotitolo}</p>
             </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6 mb-8 relative z-10">
             <div class="bg-[var(--bg-input)] backdrop-blur p-4 md:p-5 rounded-2xl border border-[var(--border-card)]">
               <span class="block text-slate-500 text-xs uppercase tracking-wider font-bold mb-1">Costo Base</span>
               <span class="font-bold text-xl text-white">{idData.hero_info.costo}</span>
             </div>
             <div class="bg-[var(--bg-input)] backdrop-blur p-4 md:p-5 rounded-2xl border border-[var(--border-card)]">
               <span class="block text-slate-500 text-xs uppercase tracking-wider font-bold mb-1">Tempi emissione</span>
               <span class="font-semibold text-sm text-slate-300">{idData.hero_info.tempi}</span>
             </div>
          </div>

          <a href={idData.hero_info.link_ufficiale} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center bg-white text-black font-bold px-6 py-3.5 md:py-4 rounded-xl text-base hover:bg-slate-200 transition-colors w-full shadow-lg relative z-10">
            Richiedi sul Sito Ufficiale
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </section>

      <section id="id-alternative" class="scroll-mt-24">
        <h4 class="text-xl md:text-2xl font-bold text-white mb-5 px-1 flex items-center gap-2.5">
            <div class="w-1.5 h-6 bg-[#0066FF] rounded-full"></div>
            Alternative Globali
        </h4>
        <div class="space-y-4">
          {idData.other_ids.map(id => (
            <div class="bento-card border-[#0066FF]/10 p-5 md:p-6">
              <div class="flex justify-between items-center mb-3">
                 <h5 class="text-base md:text-lg font-bold text-white">{id.titolo}</h5>
                 <span class="text-xs font-semibold px-2.5 py-1 bg-white/[0.05] rounded-lg text-slate-400">{id.spesa}</span>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed">{id.descrizione}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEZIONE 2: VPN NETWORK -->
      <div class="mb-4 mt-16">
         <h2 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-tight border-b border-white/[0.1] pb-3" id="vpn">2. Network VPN</h2>
         <p class="text-slate-400 text-sm md:text-[15px] leading-relaxed mt-3">{vpnData.page_description}</p>
      </div>

      <div class="space-y-6">
      {vpnData.sections.map((sec, index) => (
        <section class="scroll-mt-24">
          <h4 class="text-lg md:text-xl font-bold text-white mb-4 px-1 flex items-center gap-2.5 tracking-tight">
            <div class={`w-1 h-5 rounded-full ${index === 0 ? 'bg-purple-500' : index === 1 ? 'bg-red-500' : 'bg-[#03a66d]'}`}></div>
            {sec.titolo}
          </h4>
          
          <div class="bento-card relative p-6">
            <p class="text-slate-400 text-sm md:text-[15px] leading-relaxed mb-1">{sec.spiegazione}</p>
            
            {sec.raccomandata && (
              <div class="mt-4 p-3.5 bg-white/[0.02] border border-white/[0.06] rounded-xl flex flex-wrap items-center gap-3 w-fit">
                <span class="text-xs font-bold uppercase tracking-widest text-[#03a66d] border border-[#03a66d]/30 bg-[#03a66d]/10 px-2.5 py-1 rounded-lg">Raccomandata</span>
                <span class="text-white font-bold text-sm ml-1">{sec.raccomandata}</span>
                <a href="https://mullvad.net/it" target="_blank" rel="noopener noreferrer" class="ml-4 flex items-center gap-1.5 text-sm text-[#03a66d] hover:text-white transition-colors bg-black/50 px-3 py-1.5 rounded-lg border border-white/[0.08]">
                  Scopri ➡
                </a>
              </div>
            )}
          </div>
        </section>
      ))}
      </div>

      <!-- SEZIONE 3: EXTRA & GUIDE -->
      <div class="mb-4 mt-16" id="extra">
         <h2 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-tight border-b border-white/[0.1] pb-3">3. Strumenti Extra & Guide</h2>
      </div>

      <section class="scroll-mt-24">
        <div class="space-y-4">
            <!-- BTCPay POS SIM Alta Privacy -->
            <div class="bento-card border-orange-500/10 p-5 md:p-6">
              <div class="flex justify-between items-center mb-3">
                 <h4 class="text-base md:text-lg font-bold text-white">SIM ad Alta Privacy (Saremmo)</h4>
                 <span class="text-xs font-semibold px-2.5 py-1 bg-white/[0.05] rounded-lg text-slate-400">Strumento Flessibile</span>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed mb-4">Ottieni una SIM minimizzando l'esposizione dei tuoi documenti d'identità. Utile per l'iscrizione a servizi web preservando il proprio numero principale e mitigare il rischio di SIM swap.</p>
              <a href="https://btcpay.priorato.org/apps/4MPLLHPGGbk1bWB1Tmy7ie7dUdo3/pos" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 px-4 py-2 border border-orange-500/15 bg-orange-500/5 hover:bg-orange-500/10 hover:border-orange-500/40 rounded-xl transition-all duration-300 group cursor-pointer">
                  <span class="text-xs font-medium tracking-wider text-orange-500 group-hover:text-orange-400">Acquista su BTCPay POS</span>
              </a>
            </div>

            <!-- Turtlecute Guides -->
            <div class="bento-card border-[#0066FF]/10 p-5 md:p-6">
              <div class="flex justify-between items-center mb-3">
                 <h4 class="text-base md:text-lg font-bold text-white">Guide in Italiano (Turtlecute)</h4>
                 <span class="text-xs font-semibold px-2.5 py-1 bg-white/[0.05] rounded-lg text-slate-400">Risorsa Educativa</span>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed mb-4">Un'ampia collezione di articoli e guide tecniche completamente in italiano su Bitcoin, Privacy, Nodi e sovranità digitale.</p>
              <a href="https://turtlecute.org/posts/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 px-4 py-2 border border-[#0066FF]/15 bg-[#0066FF]/5 hover:bg-[#0066FF]/10 hover:border-[#0066FF]/40 rounded-xl transition-all duration-300 group cursor-pointer">
                  <span class="text-xs font-medium tracking-wider text-[#0066FF] group-hover:text-blue-400">Esplora le Guide</span>
              </a>
            </div>

            <!-- PlanB Academy -->
            <div class="bento-card border-[#03a66d]/10 p-5 md:p-6">
              <div class="flex justify-between items-center mb-3">
                 <h4 class="text-base md:text-lg font-bold text-white">PlanB Academy</h4>
                 <span class="text-xs font-semibold px-2.5 py-1 bg-white/[0.05] rounded-lg text-slate-400">Risorsa Educativa</span>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed mb-4">Tutorial e materiali educativi approfonditi gratuiti su Bitcoin, wallet e privacy finanziaria.</p>
              <a href="https://planb.academy/en/tutorials/wallet" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 px-4 py-2 border border-[#03a66d]/15 bg-[#03a66d]/5 hover:bg-[#03a66d]/10 hover:border-[#03a66d]/40 rounded-xl transition-all duration-300 group cursor-pointer">
                  <span class="text-xs font-medium tracking-wider text-[#03a66d] group-hover:text-green-400">Visita l'Academy</span>
              </a>
            </div>
        </div>
      </section>

      <!-- SEZIONE 4: OPSEC E SICUREZZA PERSONALE -->
      <div class="mb-4 mt-16" id="opsec">
         <h2 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-tight border-b border-white/[0.1] pb-3">4. Sicurezza Personale (OpSec)</h2>
         <p class="text-slate-400 text-sm md:text-[15px] leading-relaxed mt-3">Proteggere le tue crypto non significa solo custodire le chiavi private, ma proteggere te stesso e la tua identità fisica dalle conseguenze nel mondo reale (rapimenti, estorsioni, furti in casa).</p>
      </div>

      <section class="scroll-mt-24">
        <div class="space-y-4">
            <div class="bento-card border-red-500/10 p-5 md:p-6 bg-gradient-to-br from-red-500/5 to-transparent">
              <div class="flex justify-between items-center mb-3">
                 <h4 class="text-base md:text-lg font-bold text-white">Il rischio Data Leak</h4>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed mb-4">Le aziende centralizzate subiscono costantemente violazioni. Il <strong>Ledger Leak del 2020</strong> ha esposto nome, cognome, numero di telefono e indirizzo di casa di oltre 270.000 utenti crypto. Se hai un bilancio rilevante, e il tuo indirizzo di casa finisce online associato al fatto che possiedi crypto, diventi un bersaglio per estorsioni e rapimenti. <strong>Regola d'oro:</strong> Non usare MAI il tuo vero indirizzo per farti spedire hardware wallet. Usa Locker, punti di ritiro o uffici.</p>
            </div>
            
            <div class="bento-card border-red-500/10 p-5 md:p-6 bg-gradient-to-br from-red-500/5 to-transparent">
              <div class="flex justify-between items-center mb-3">
                 <h4 class="text-base md:text-lg font-bold text-white">Tax Software e KYC</h4>
              </div>
              <p class="text-sm md:text-[15px] text-slate-400 leading-relaxed mb-4">Evita di inserire veri documenti, veri nomi o veri indirizzi su piattaforme web per il tax reporting automatico (come Koinly, Blockpit). Usa pseudonimi e email dedicate. Lo stesso vale per app e servizi correlati. Meno leghi la tua identità fisica on-chain, più la tua incolumità è preservata.</p>
            </div>
        </div>
      </section>

      <!-- Combined FAQ -->
      <section id="faq" class="scroll-mt-24 mt-16">
        <h3 class="text-xl md:text-2xl font-bold text-white mb-5 px-1 flex items-center gap-2.5">
            <div class="w-1.5 h-6 bg-purple-500 rounded-full"></div>
            Domande Frequenti (Digital ID)
        </h3>
        <div class="space-y-2.5">
          {idData.faq.map(f => (
            <Accordion title={f.domanda}>
              <p class="text-sm md:text-[15px] font-medium leading-relaxed" set:html={f.risposta}></p>
            </Accordion>
          ))}
        </div>
      </section>
      
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
