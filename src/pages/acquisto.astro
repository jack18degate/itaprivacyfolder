---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import Accordion from '../components/Accordion.astro';
import CompareModule from '../components/CompareModule.astro';
import exData from '../data/exchanges.json';

const allAcquistoItems = [
  ...exData.p2p.map(e => ({...e, id: 'p2p-'+e.nome.replace(/\s+/g, '-'), categoria_badge: 'Rete P2P'})),
  ...(exData.light_kyc ? exData.light_kyc.map(e => ({...e, id: 'light-'+e.nome.replace(/\s+/g, '-'), categoria_badge: 'On-Ramp Light KYC'})) : [])
];

const acquistoFields = [
  { key: 'kyc', label: 'KYC Status', type: 'badge' },
  { key: 'consigliato', label: 'Consigliato Per', type: 'text' },
  { key: 'pro', label: 'Pro', type: 'list' }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "it",
  "mainEntity": exData.faq_acquisto.map(item => ({
    "@type": "Question",
    "name": item.domanda,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.risposta.replace(/<[^>]+>/g, '') // Strip HTML for schema
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://privacy-crypto.com/" },
    { "@type": "ListItem", "position": 2, "name": "Acquista Crypto" }
  ]
};
---

<Layout title={exData.page_title_acquisto} description="Scopri come acquistare Bitcoin e crypto minimizzando il KYC. Piattaforme P2P, broker Light-KYC e metodi On-Ramp sicuri." maxWidth="max-w-[1300px] xl:max-w-[1400px]">

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 xl:gap-12 items-start mt-2">
    <!-- Sidebar Navigation Left -->
    <div class="hidden lg:block w-[240px] xl:w-[270px] shrink-0 sticky top-24 order-2 lg:order-1">
      <div class="bento-card p-6 border-white/[0.03] shadow-2xl bg-[var(--bg-sidebar)]">
         <h4 class="text-xs uppercase tracking-widest font-black text-slate-600 mb-5">Indice della Guida</h4>
         <nav class="flex flex-col space-y-3.5">
            <a href="#intro" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               On-Ramp vs P2P
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>

            <hr class="border-white/[0.03]" />
            <a href="#faq" class="text-sm text-slate-500 hover:text-[#0066FF] font-medium flex items-center justify-between group transition-colors">
               F.A.Q.
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <hr class="border-white/[0.03]" />
            <a href="/exchange/" class="text-sm text-[#0066FF] hover:text-[#0066FF] font-bold flex items-center justify-between group transition-colors mt-2">
               → Exchange CEX/DEX
               <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
         </nav>
       </div>
    </div>

    <!-- Main Content Right -->
    <div class="flex-1 min-w-0 space-y-6 lg:space-y-10 order-1 lg:order-2 w-full">
      <header class="mb-6 lg:mb-8 border-b border-white/[0.05] pb-5 lg:pb-6">
    <div class="inline-block px-3 py-1 mb-3 border border-orange-500/20 bg-orange-500/10 rounded-full text-xs font-bold tracking-wider text-orange-500 uppercase">Acquisto</div>
    <h1 class="text-2xl lg:text-4xl font-extrabold tracking-tight mb-3 text-white">{exData.page_title_acquisto}</h1>
    <div class="p-4 lg:p-5 bg-[var(--bg-sidebar)] border-l-[3px] border-orange-500 rounded-r-xl">
      <p class="text-slate-400 text-[15px] md:text-base leading-relaxed">{exData.page_description_acquisto}</p>
    </div>
  </header>

  <!-- Sezione Intro: Differenze On-Ramp vs P2P -->
  <section id="intro" class="scroll-mt-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
      <!-- P2P Card -->
      <div class="bento-card p-5 md:p-6 border-orange-500/20 bg-gradient-to-br from-orange-900/10 to-transparent relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-orange-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-orange-500/10 border border-orange-500/30 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-lg">P2P — Peer to Peer</h3>
              <span class="text-xs text-orange-400 font-bold uppercase tracking-wider">Massima Privacy</span>
            </div>
          </div>
          <ul class="space-y-2.5 text-sm text-slate-400">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">No-KYC:</strong> Nessun documento richiesto</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Diretto:</strong> Scambi tra privati cittadini via SEPA/contanti</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Escrow:</strong> Smart Contract protegge entrambe le parti</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">Nota:</strong> Liquidità limitata, prezzi con premio (2-5%)</span></li>
          </ul>
        </div>
      </div>

      <!-- On-Ramp Card -->
      <div class="bento-card p-5 md:p-6 border-yellow-500/20 bg-gradient-to-br from-yellow-900/10 to-transparent relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-yellow-500/5 -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-yellow-500/10 border border-yellow-500/30 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-lg">On-Ramp — Broker Light</h3>
              <span class="text-xs text-yellow-500 font-bold uppercase tracking-wider">KYC Leggero</span>
            </div>
          </div>
          <ul class="space-y-2.5 text-sm text-slate-400">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Rapido:</strong> Bonifico → crypto in pochi minuti</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Self-Custody:</strong> Le crypto arrivano direttamente nel tuo wallet</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-[#03a66d] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span><strong class="text-white">Limiti bassi:</strong> Verifiche minime sotto soglia (es. &lt;1000€)</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg><span><strong class="text-white">Nota:</strong> Comunque un'azienda intermedia (potenziale DAC8)</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  
  <CompareModule items={allAcquistoItems} fields={acquistoFields} tableTitle="Confronto Metodi di Acquisto" />

    <!-- F.A.Q. Acquisto -->
    <section id="faq" class="scroll-mt-24">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 px-1">Domande Frequenti (F.A.Q)</h2>
      <div class="space-y-3">
        {exData.faq_acquisto.map((item) => (
            <Accordion title={item.domanda}>
              <p class="text-[15px] font-medium leading-relaxed" set:html={item.risposta}></p>
            </Accordion>
        ))}
      </div>
    </section>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
