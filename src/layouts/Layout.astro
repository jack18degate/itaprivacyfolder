       </nav>


    </div>

    <script is:inline>
      // â•â•â• Theme Toggle â•â•â•
      function applyTheme(theme) {
         if (theme === 'light') {
            document.documentElement.classList.add('light-theme');
         } else {
            document.documentElement.classList.remove('light-theme');
         }
      }

      function toggleTheme() {
         const isLight = document.documentElement.classList.contains('light-theme');
         const newTheme = isLight ? 'dark' : 'light';
         localStorage.setItem('theme', newTheme);
         applyTheme(newTheme);
      }

      const initTheme = () => {
         const saved = localStorage.getItem('theme') || 'dark';
         applyTheme(saved);
      };

      // ═══ Active Link highlight ═══
      const initNav = () => {
         const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
         document.querySelectorAll('.nav-link').forEach(link => {
            const href = (link.getAttribute('href') || '').replace(/\/$/, '') || '/';
            if(href === currentPath) {
               link.classList.add('font-bold');
               link.style.color = 'var(--text-heading)';
            } else {
               link.classList.remove('font-bold');
               link.style.color = '';
            }
         });
      };

      // ═══ Event Delegation (Mobile Menu + Theme Toggle + Language Switch) ═══
      document.addEventListener('click', (e) => {
         const hamBtn = e.target.closest('#hamburger-btn');
         const closeBtn = e.target.closest('#close-menu-btn');
         const themeBtn = e.target.closest('#theme-toggle-desktop') || e.target.closest('#theme-toggle-mobile');
         const langSwitch = e.target.closest('[data-lang-switch]');
         const mobileMenu = document.getElementById('mobile-menu');

         if (langSwitch) {
            const targetLang = langSwitch.getAttribute('data-lang-switch');
            document.cookie = 'lang-pref=' + targetLang + ';path=/;max-age=31536000;SameSite=Lax';
         }
         if (themeBtn) {
            toggleTheme();
         }
         if (hamBtn && mobileMenu) {
             mobileMenu.classList.remove('translate-x-full');
         }
         if (closeBtn && mobileMenu) {
             mobileMenu.classList.add('translate-x-full');
         }
      });

      // â•â•â• Scroll Reveal — IntersectionObserver â•â•â•
      const initReveal = () => {
         const reveals = document.querySelectorAll('.reveal');
         if (reveals.length === 0) return;
         
         const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
               if (entry.isIntersecting) {
                  entry.target.classList.add('active');
               }
            });
         }, { threshold: 0, rootMargin: '0px 0px -50px 0px' });
         
         reveals.forEach(el => observer.observe(el));
      };

      // â•â•â• Init on page load â•â•â•
      const initAll = () => { initTheme(); initNav(); initReveal(); };

      document.addEventListener('astro:page-load', initAll);
      if (document.readyState === 'loading') {
         document.addEventListener('DOMContentLoaded', initAll);
      } else {
         initAll();
      }
    </script>
</body>
