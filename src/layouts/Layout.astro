---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';
const { title, description = "Privacy Toolkit per utenti crypto italiani. Normative, exchange, wallet e strumenti per proteggere la tua indipendenza finanziaria.", maxWidth = "max-w-5xl" } = Astro.props;

const currentPath = Astro.url.pathname;
let utmContent = 'home';
if (currentPath.includes('/exchange')) utmContent = 'exchange';
else if (currentPath.includes('/wallets')) utmContent = 'wallets';
else if (currentPath.includes('/fisco/dac8-guida-completa')) utmContent = 'dac8_guide';
else if (currentPath.includes('/fisco')) utmContent = 'fisco';
else if (currentPath.includes('/privacy-coins')) utmContent = 'privacy_coins';

const baseUtm = `utm_source=it_privacy_site&utm_content=${utmContent}`;
const degateLink = `https://app.degate.com/it/?s=jack18&${baseUtm}`;
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Italian Privacy Toolkit</title>
    <meta name="description" content={description}>
    <SEO title={title} description={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <script is:inline>
      // Prevent flash: apply theme before paint
      (function() {
        const t = localStorage.getItem('theme');
        if (t === 'light') document.documentElement.classList.add('light-theme');
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JC1QFGXSDF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-JC1QFGXSDF');
    </script>
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="7d5f5c8d-027b-4278-8b1c-1606e2c1df6a"></script>
</head>
<body class="flex flex-col min-h-screen relative" id="app-body">
    <Analytics />
    <!-- Navbar — Full-width -->
    <header class="w-full border-b relative z-20 backdrop-blur-xl sticky top-0" style="border-color: var(--navbar-border); background-color: var(--navbar-bg);">
        <div class={`w-full ${maxWidth} mx-auto px-4 lg:px-6 py-3 flex items-center justify-between`}>
            <a href="/" class="flex items-center gap-2.5 text-white hover:opacity-80 transition-opacity">
                <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#0066FF] to-[#03a66d] flex items-center justify-center shadow-lg shadow-blue-500/20">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
                <span class="text-[16px] font-bold tracking-tight text-white">Privacy<span class="text-slate-500 font-normal ml-0.5">Toolkit</span></span>
            </a>
            
            <div class="hidden lg:flex items-center gap-5 xl:gap-7 text-[14px] xl:text-[15px] font-medium text-slate-400 whitespace-nowrap shrink-0" id="desktop-nav">
                <a href="/fisco" class="nav-link hover:text-white transition-colors duration-200">Tasse & Burocrazia</a>
                <a href="/exchange" class="nav-link hover:text-white transition-colors duration-200">Exchange</a>
                <a href="/acquisto" class="nav-link hover:text-white transition-colors duration-200">Acquisto</a>
                <a href="/spend" class="nav-link hover:text-white transition-colors duration-200">Spendi Crypto</a>
                <a href="/wallets" class="nav-link hover:text-white transition-colors duration-200">Portafogli</a>
                <a href="/privacy-coins" class="nav-link hover:text-white transition-colors duration-200">Privacy Coins</a>
                <a href="/varie" class="nav-link hover:text-white transition-colors duration-200">Varie</a>
                
                <div class="w-px h-5 bg-white/[0.08] mx-1"></div>
                
                <!-- Theme Toggle (Desktop) -->
                <button id="theme-toggle-desktop" class="theme-toggle" aria-label="Cambia tema">
                  <svg class="w-4 h-4 icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                  <svg class="w-4 h-4 icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </button>
                

            </div>

            <!-- Mobile buttons -->
            <div class="flex items-center gap-2 lg:hidden ml-auto">
               <!-- Theme Toggle (Mobile) -->
               <button id="theme-toggle-mobile" class="theme-toggle" aria-label="Cambia tema">
                  <svg class="w-4 h-4 icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                  <svg class="w-4 h-4 icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
               </button>
               <button id="hamburger-btn" class="p-1" style="color: var(--text-muted);" aria-label="Apri menu">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
               </button>
            </div>
        </div>
    </header>

    <main class={`flex-grow w-full ${maxWidth} mx-auto px-4 lg:px-6 py-6 lg:py-12 relative z-10`}>
        <slot />
    </main>
    
    <footer class="text-center px-4 py-8 mt-auto relative z-10 border-t" style="border-color: var(--footer-border);">
        
        <!-- SPONSOR BANNER DEGATE -->
        <div class="max-w-4xl mx-auto mb-10 relative group text-left">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-[#0066FF] to-[#03a66d] rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-500"></div>
            <div class="relative bento-card p-6 sm:p-8 flex flex-col sm:flex-row items-center sm:items-start md:items-center gap-6 justify-between">
                <!-- Icon/Logo & Text -->
                <div class="flex flex-col sm:flex-row items-center sm:items-start md:items-center gap-5 text-center sm:text-left">
                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-white/[0.02] border border-white/[0.1] flex items-center justify-center p-2.5 shadow-inner">
                        <img src="https://www.google.com/s2/favicons?domain=degate.com&sz=128" alt="DeGate Logo" class="w-full h-full object-contain drop-shadow-md" />
                    </div>
                    <div>
                        <h3 class="text-white font-bold text-lg sm:text-xl mb-1 flex items-center justify-center sm:justify-start gap-2">
                            Sito Sostenuto da DeGate Wallet
                            <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                        </h3>
                        <p class="text-slate-400 text-sm sm:text-base leading-relaxed max-w-lg">
                            Il modo più facile e privacy oriented per gestire le tue crypto.
                        </p>
                    </div>
                </div>
                
                <!-- Buttons (Desktop/Mobile controlled by CSS) -->
                <div class="shrink-0 w-full md:w-auto mt-4 sm:mt-0 flex flex-col gap-3">
                    <!-- Desktop Link (hidden on mobile) -->
                    <a href={degateLink} target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/[0.05] hover:bg-[#0066FF] border border-white/[0.1] hover:border-[#0066FF] text-white font-semibold text-[15px] rounded-xl transition-all shadow-lg hover:shadow-[#0066FF]/20">
                        Self-Custody con Swap Integrato — Inizia Ora
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                    <!-- Mobile Link (hidden on desktop) -->
                    <a href={degateLink} target="_blank" rel="noopener noreferrer" class="sm:hidden w-full flex justify-center items-center gap-2 px-6 py-3.5 bg-gradient-to-r from-[#0066FF] to-[#0055DD] hover:from-[#0055DD] hover:to-[#0044BB] text-white font-bold text-[15px] rounded-xl transition-all shadow-lg shadow-[#0066FF]/25">
                        Inizia con DeGate
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    </a>
                </div>
            </div>
        </div>

        <p class="text-slate-500 text-sm font-medium">&copy; {new Date().getFullYear()} — Strumenti per la Privacy Finanziaria in Italia.</p>
        
        <p class="max-w-3xl mx-auto my-4 text-xs text-slate-600 leading-relaxed px-4 text-justify sm:text-center border border-white/[0.04] bg-white/[0.01] p-4 rounded-2xl">
            <strong class="text-slate-500 uppercase tracking-widest block mb-1.5 text-[11px]">Disclaimer di Responsabilità</strong> 
            Tutte le piattaforme, software e servizi citati in questo hub sono risorse reperite online, catalogate a scopo puramente didattico e non costituiscono consulenza finanziaria. L'architettura del Web3 e della DeFi è altamente sperimentale. Gli autori non si assumono alcuna responsabilità legale, patrimoniale o tecnica imputabile a malfunzionamenti, bug, exploit hacker o perdite di capitale derivanti dall'utilizzo diretto o indiretto di queste applicazioni di terze parti. Agisci nel mercato solo previa accurata ricerca personale (DYOR).
        </p>



    </footer>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 backdrop-blur-3xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col pt-6 pb-8 px-6 overflow-y-auto" style="background-color: var(--menu-bg);">
       <div class="flex justify-between items-center mb-10">
          <span class="text-lg font-bold tracking-tight text-white flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#0066FF] to-[#03a66d] flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            Menu Navigazione
          </span>
          <button id="close-menu-btn" class="text-slate-500 hover:text-white bg-white/[0.08] hover:bg-white/[0.15] border border-white/[0.12] p-2 rounded-full transition-colors shadow-lg">
             <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
       </div>
       <nav class="flex flex-col gap-6 text-lg font-medium">
          <a href="/" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg> Home</a>
          <a href="/fisco" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" /></svg> Tasse & Obblighi</a>
          <a href="/exchange" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path d="M8 5a1 1 0 100 2h5.586l-1.293 1.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L13.586 5H8zM12 15a1 1 0 100-2H6.414l1.293-1.293a1 1 0 10-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L6.414 15H12z"/></svg> Exchange (CEX/DEX)</a>
          <a href="/acquisto" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Acquisto (P2P/Ramp)</a>
          <a href="/spend" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg> Spendi Crypto</a>
          <a href="/wallets" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg> Portafogli & Storage</a>
          <a href="/privacy-coins" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg> Privacy Coins</a>
          <a href="/varie" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg> Varie</a>
       </nav>


    </div>

    <script is:inline>
      // â•â•â• Theme Toggle â•â•â•
      function applyTheme(theme) {
         if (theme === 'light') {
            document.documentElement.classList.add('light-theme');
         } else {
            document.documentElement.classList.remove('light-theme');
         }
      }

      function toggleTheme() {
         const isLight = document.documentElement.classList.contains('light-theme');
         const newTheme = isLight ? 'dark' : 'light';
         localStorage.setItem('theme', newTheme);
         applyTheme(newTheme);
      }

      const initTheme = () => {
         const saved = localStorage.getItem('theme') || 'dark';
         applyTheme(saved);
      };

      // â•â•â• Active Link highlight â•â•â•
      const initNav = () => {
         const currentPath = window.location.pathname;
         document.querySelectorAll('.nav-link').forEach(link => {
            if(link.getAttribute('href') === currentPath) {
               link.classList.add('font-bold');
               link.style.color = 'var(--text-heading)';
            } else {
               link.classList.remove('font-bold');
               link.style.color = '';
            }
         });
      };

      // â•â•â• Event Delegation (Mobile Menu + Theme Toggle) â•â•â•
      document.addEventListener('click', (e) => {
         const hamBtn = e.target.closest('#hamburger-btn');
         const closeBtn = e.target.closest('#close-menu-btn');
         const themeBtn = e.target.closest('#theme-toggle-desktop') || e.target.closest('#theme-toggle-mobile');
         const mobileMenu = document.getElementById('mobile-menu');

         if (themeBtn) {
            toggleTheme();
         }
         if (hamBtn && mobileMenu) {
             mobileMenu.classList.remove('translate-x-full');
         }
         if (closeBtn && mobileMenu) {
             mobileMenu.classList.add('translate-x-full');
         }
      });

      // â•â•â• Scroll Reveal — IntersectionObserver â•â•â•
      const initReveal = () => {
         const reveals = document.querySelectorAll('.reveal');
         if (reveals.length === 0) return;
         
         const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
               if (entry.isIntersecting) {
                  entry.target.classList.add('active');
               }
            });
         }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
         
         reveals.forEach(el => observer.observe(el));
      };

      // â•â•â• Init on page load â•â•â•
      const initAll = () => { initTheme(); initNav(); initReveal(); };

      document.addEventListener('astro:page-load', initAll);
      if (document.readyState === 'loading') {
         document.addEventListener('DOMContentLoaded', initAll);
      } else {
         initAll();
      }
    </script>
</body>
</html>
