---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';
import { useTranslations, getAlternateUrl, type Lang } from '../i18n/utils';

const { title, description, maxWidth = "max-w-5xl", noindex = false, lang = 'it' as Lang } = Astro.props;
const t = useTranslations(lang);
const defaultDesc = lang === 'en'
  ? 'Privacy Toolkit for crypto users. Exchanges, wallets, and tools to protect your financial independence.'
  : 'Privacy Toolkit per utenti crypto italiani. Normative, exchange, wallet e strumenti per proteggere la tua indipendenza finanziaria.';
const pageDescription = description || defaultDesc;

const currentPath = Astro.url.pathname;
const altLang = lang === 'en' ? 'it' : 'en';
const altUrl = getAlternateUrl(currentPath, altLang as Lang);

let utmContent = 'home';
if (currentPath.includes('/exchange-crypto-mica') || currentPath.includes('/mica-compliant')) utmContent = 'mica_registry';
else if (currentPath.includes('/exchange')) utmContent = 'exchange';
else if (currentPath.includes('/wallets')) utmContent = 'wallets';
else if (currentPath.includes('/fisco/dac8-guida-completa')) utmContent = 'dac8_guide';
else if (currentPath.includes('/fisco')) utmContent = 'fisco';
else if (currentPath.includes('/privacy-coins')) utmContent = 'privacy_coins';
else if (currentPath.includes('/guide')) utmContent = 'guide';

const utmSource = lang === 'en' ? 'en_privacy_site' : 'it_privacy_site';
const baseUtm = `utm_source=${utmSource}&utm_content=${utmContent}`;
const degateLink = lang === 'en' ? `https://app.degate.com/?s=jack18&${baseUtm}` : `https://app.degate.com/it/?s=jack18&${baseUtm}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Preconnect for external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://cloud.umami.is" />
    <!-- Font loading (moved from CSS @import for performance) -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" /></noscript>
    <!-- LLM/GEO discovery -->
    <link rel="help" type="text/plain" href="/llms.txt" title="LLM site index" />
    <link rel="help" type="text/plain" href="/llms-full.txt" title="Full LLM context with guide content" />
    <title>{title} | {t('site.suffix')}</title>
    <meta name="description" content={pageDescription}>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <SEO title={title} description={pageDescription} lang={lang} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg?v=2" />
    <ClientRouter />
    <script is:inline>
      // Prevent flash: apply theme before paint
      (function() {
        const t = localStorage.getItem('theme');
        if (t === 'light') document.documentElement.classList.add('light-theme');
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JC1QFGXSDF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-JC1QFGXSDF');
    </script>
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="7d5f5c8d-027b-4278-8b1c-1606e2c1df6a"></script>
</head>
<body class="flex flex-col min-h-screen relative" id="app-body">
    <Analytics />
    <!-- Navbar — Full-width -->
    <header class="w-full border-b relative z-20 backdrop-blur-xl sticky top-0" style="border-color: var(--navbar-border); background-color: var(--navbar-bg);">
        <div class={`w-full ${maxWidth} mx-auto px-4 lg:px-6 py-3 flex items-center justify-between`}>
            <a href={t('link.home')} class="flex items-center gap-2.5 text-white hover:opacity-80 transition-opacity">
                <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#0066FF] to-[#03a66d] flex items-center justify-center shadow-lg shadow-blue-500/20">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
                <span class="text-[16px] font-bold tracking-tight text-white">Privacy<span class="text-slate-500 font-normal ml-0.5">Toolkit</span></span>
            </a>
                        <div class="hidden lg:flex flex-col gap-1.5 items-end" id="desktop-nav">
                <!-- Row 1: Fisco, Exchange, Acquisto, Spendi, Portafogli -->
                <div class="flex items-center gap-4 xl:gap-6 text-[13px] xl:text-[14px] font-medium text-slate-400 whitespace-nowrap shrink-0">
                    {lang === 'it' && <a href="/fisco/" class="nav-link hover:text-white transition-colors duration-200">{t('nav.tax')}</a>}
                    <a href={t('link.exchange')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.exchange')}</a>
                    <a href={t('link.purchase')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.purchase')}</a>
                    <a href={t('link.spend')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.spend')}</a>
                    <a href={t('link.wallets')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.wallets')}</a>
                </div>
                <!-- Row 2: Privacy Coins, Varie/Misc, Guide, MiCA + utilities -->
                <div class="flex items-center gap-4 xl:gap-6 text-[13px] xl:text-[14px] font-medium text-slate-400 whitespace-nowrap shrink-0">
                    <a href={t('link.privacy-coins')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.privacy-coins')}</a>
                    <a href={t('link.misc')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.misc')}</a>
                    <a href={t('link.guides')} class="nav-link hover:text-white transition-colors duration-200">{t('nav.guides')}</a>
                    
                    <a href={t('link.mica')} class="nav-link flex items-center gap-1.5 font-semibold text-amber-500/80 hover:text-amber-400 transition-colors duration-200">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        {t('nav.mica')}
                        <span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-amber-500/10 text-amber-500 border border-amber-500/20 uppercase tracking-wider">EU</span>
                    </a>
                    
                    <div class="w-px h-4 bg-white/[0.08]"></div>
                    
                    <!-- Language Switcher (Desktop) -->
                    <a href={altUrl} class="flex items-center gap-1.5 text-slate-400 hover:text-white transition-colors duration-200 text-[13px] font-semibold" title={lang === 'en' ? 'Versione Italiana' : 'English Version'} data-lang-switch={altLang}>
                      {lang === 'en' ? '🇮🇹 IT' : '🇬🇧 EN'}
                    </a>
                    
                    <!-- Theme Toggle (Desktop) -->
                    <button id="theme-toggle-desktop" class="theme-toggle" aria-label={t('theme.toggle')}>
                      <svg class="w-4 h-4 icon-moon" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                      <svg class="w-4 h-4 icon-sun" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    </button>
                </div>
            </div>

            <!-- Mobile buttons -->
            <div class="flex items-center gap-2 lg:hidden ml-auto">
               <!-- Language Switcher (Mobile) -->
               <a href={altUrl} class="text-slate-400 hover:text-white text-[13px] font-semibold px-1" title={lang === 'en' ? 'Versione Italiana' : 'English Version'} data-lang-switch={altLang}>
                 {lang === 'en' ? '🇮🇹' : '🇬🇧'}
               </a>
               <!-- Theme Toggle (Mobile) -->
               <button id="theme-toggle-mobile" class="theme-toggle" aria-label={t('theme.toggle')}>
                  <svg class="w-4 h-4 icon-moon" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                  <svg class="w-4 h-4 icon-sun" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
               </button>
               <button id="hamburger-btn" class="p-1" style="color: var(--text-muted);" aria-label={t('menu.open')}>
                  <svg class="w-6 h-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
               </button>
            </div>
        </div>
    </header>

    <main class={`flex-grow w-full ${maxWidth} mx-auto px-4 lg:px-6 py-6 lg:py-12 relative z-10`}>
        <slot />
    </main>
    
    <footer class="text-center px-4 py-8 mt-auto relative z-10 border-t" style="border-color: var(--footer-border);">
        
        <!-- SPONSOR BANNER DEGATE -->
        <div class="max-w-4xl mx-auto mb-10 relative group text-left">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-[#0066FF] to-[#03a66d] rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-500"></div>
            <div class="relative bento-card p-6 sm:p-8 flex flex-col sm:flex-row items-center sm:items-start md:items-center gap-6 justify-between">
                <!-- Icon/Logo & Text -->
                <div class="flex flex-col sm:flex-row items-center sm:items-start md:items-center gap-5 text-center sm:text-left">
                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-white/[0.02] border border-white/[0.1] flex items-center justify-center p-2.5 shadow-inner">
                        <img src="https://www.google.com/s2/favicons?domain=degate.com&sz=128" alt="DeGate Logo" class="w-full h-full object-contain drop-shadow-md" />
                    </div>
                    <div>
                        <h3 class="text-white font-bold text-lg sm:text-xl mb-1 flex items-center justify-center sm:justify-start gap-2">
                            {t('sponsor.title')}
                            <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                        </h3>
                        <p class="text-slate-400 text-sm sm:text-base leading-relaxed max-w-lg">
                            {t('sponsor.description')}
                        </p>
                    </div>
                </div>
                
                <!-- Buttons (Desktop/Mobile controlled by CSS) -->
                <div class="shrink-0 w-full md:w-auto mt-4 sm:mt-0 flex flex-col gap-3">
                    <!-- Desktop Link (hidden on mobile) -->
                    <a href={degateLink} target="_blank" rel="sponsored nofollow noopener noreferrer" class="hidden sm:inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/[0.05] hover:bg-[#0066FF] border border-white/[0.1] hover:border-[#0066FF] text-white font-semibold text-[15px] rounded-xl transition-all shadow-lg hover:shadow-[#0066FF]/20">
                        {t('sponsor.cta.desktop')}
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                    <!-- Mobile Link (hidden on desktop) -->
                    <a href={degateLink} target="_blank" rel="sponsored nofollow noopener noreferrer" class="sm:hidden w-full flex justify-center items-center gap-2 px-6 py-3.5 bg-gradient-to-r from-[#0066FF] to-[#0055DD] hover:from-[#0055DD] hover:to-[#0044BB] text-white font-bold text-[15px] rounded-xl transition-all shadow-lg shadow-[#0066FF]/25">
                        {t('sponsor.cta.mobile')}
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="flex flex-wrap justify-center gap-6 text-[15px] text-slate-400 mb-6 font-medium">
            <a href={t('link.about')} class="hover:text-white transition-colors">{t('footer.about')}</a>
            <a href={t('link.contact')} class="hover:text-white transition-colors">{t('footer.contact')}</a>
            <a href={t('link.privacy-policy')} class="hover:text-white transition-colors">{t('footer.privacy')}</a>
            <a href={t('link.cookie-policy')} class="hover:text-white transition-colors">{t('footer.cookie')}</a>
        </div>
        
        <p class="text-slate-500 text-sm font-medium">&copy; {new Date().getFullYear()} — {t('footer.copyright')}</p>
        
        <p class="max-w-3xl mx-auto my-4 text-xs text-slate-500 leading-relaxed px-4 text-justify sm:text-center border border-white/[0.04] bg-white/[0.01] p-4 rounded-2xl">
            <strong class="text-slate-400 uppercase tracking-widest block mb-1.5 text-[11px]">{t('footer.disclaimer.title')}</strong> 
            <Fragment set:html={t('footer.disclaimer.text')} />
        </p>



    </footer>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 backdrop-blur-3xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col pt-6 pb-8 px-6 overflow-y-auto" style="background-color: var(--menu-bg);">
       <div class="flex justify-between items-center mb-10">
          <span class="text-lg font-bold tracking-tight text-white flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#0066FF] to-[#03a66d] flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            {t('nav.mobile.title')}
          </span>
          <button id="close-menu-btn" aria-label={t('menu.close')} class="text-slate-500 hover:text-white bg-white/[0.08] hover:bg-white/[0.15] border border-white/[0.12] p-2 rounded-full transition-colors shadow-lg">
             <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
       </div>
       <nav class="flex flex-col gap-6 text-lg font-medium">
          <a href={t('link.home')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg> {t('nav.mobile.home')}</a>
          {lang === 'it' && <a href="/fisco/" class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-[#0066FF]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" /></svg> {t('nav.mobile.tax')}</a>}
          <a href={t('link.exchange')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path d="M8 5a1 1 0 100 2h5.586l-1.293 1.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L13.586 5H8zM12 15a1 1 0 100-2H6.414l1.293-1.293a1 1 0 10-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L6.414 15H12z"/></svg> {t('nav.mobile.exchange')}</a>
          <a href={t('link.mica')} class="text-amber-500/80 hover:text-amber-400 flex items-center gap-3 transition-colors ml-2"><svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg> {t('nav.mobile.mica')}</a>
          <a href={t('link.purchase')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> {t('nav.mobile.purchase')}</a>
          <a href={t('link.spend')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg> {t('nav.mobile.spend')}</a>
          <a href={t('link.wallets')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg> {t('nav.mobile.wallets')}</a>
          <a href={t('link.privacy-coins')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg> {t('nav.mobile.privacy-coins')}</a>
          <a href={t('link.misc')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg> {t('nav.mobile.misc')}</a>
          <a href={t('link.guides')} class="text-slate-400 hover:text-white flex items-center gap-3 transition-colors"><svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg> {t('nav.mobile.guides')}</a>
